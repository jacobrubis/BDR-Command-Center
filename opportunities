      </div>
    </div>`;
}

// ── UPDATE MODAL ──────────────────────────────────────────────────────────
function openUpdateModal(i) {
  const u = UPDATES[i];
  if(!u) return;
  document.getElementById('modal-root').innerHTML = `
    <div class="modal-bg" onclick="if(event.target===this)closeModal()">
      <div class="modal">
        <div class="modal-hd">
          <div>
            <div class="opty-id" style="margin-bottom:3px">${u.optyId}</div>
            <div class="modal-title">${u.account} — ${u.product}</div>
          </div>
          <button class="modal-close" onclick="closeModal()">×</button>
        </div>
        <div class="modal-body">
          <div style="font-size:11px;color:var(--s400);margin-bottom:12px;display:flex;align-items:center;gap:8px">
            ${aeBubble(u.ae)}
            <span style="font-weight:500;color:var(--s600)">${u.author}</span>
            <span>·</span>
            <span>${u.date}</span>
          </div>
          <div style="padding:14px 16px;background:var(--s50);border:1px solid var(--s200);border-left:3px solid var(--ink);border-radius:0 8px 8px 0;font-size:13px;color:var(--s700);line-height:1.7;white-space:pre-line">${u.body}</div>
          <div style="margin-top:14px;display:flex;gap:8px">
            <button class="btn btn-p btn-sm" onclick="closeModal();openOptyModal('${u.optyId}')">View Opportunity →</button>
            <button class="btn btn-g btn-sm" onclick="closeModal()">Close</button>
          </div>
        </div>
      </div>
    </div>`;
}

function showAllUpdates() {
  document.getElementById('modal-root').innerHTML = `
    <div class="modal-bg" onclick="if(event.target===this)closeModal()">
      <div class="modal" style="width:min(700px,96vw)">
        <div class="modal-hd">
          <div class="modal-title">All Opportunity Updates</div>
          <button class="modal-close" onclick="closeModal()">×</button>
        </div>
        <div class="modal-body" style="display:flex;flex-direction:column;gap:12px">
          ${UPDATES.map((u,i) => `
            <div style="padding:13px 15px;background:var(--s50);border:1px solid var(--s200);border-left:3px solid var(--ink);border-radius:0 8px 8px 0;cursor:pointer" onclick="closeModal();openUpdateModal(${i})">
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap">
                <span class="opu-chip">${u.optyId}</span>
                <span style="font-size:12px;font-weight:600;color:var(--s800)">${u.account}</span>
                <span style="font-size:11px;color:var(--s500)">${u.product}</span>
                <span style="margin-left:auto;font-size:11px;color:var(--s400)">${u.date} · ${u.author}</span>
              </div>
              <div style="font-size:12px;color:var(--s600);line-height:1.55;display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden;-webkit-line-clamp:2">${u.body}</div>
              <div style="font-size:11px;color:var(--b600);margin-top:5px">Read full note →</div>
            </div>
          `).join('')}
        </div>
      </div>
    </div>`;
}

function closeModal() {
  document.getElementById('modal-root').innerHTML = '';
}

// ── INIT ──────────────────────────────────────────────────────────────────
renderTable();
renderUpdates();
renderAEBreakdown();
</script>
