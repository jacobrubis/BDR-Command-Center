// ── RENDER AE BREAKDOWN ───────────────────────────────────────────────────
function renderAEBreakdown() {
  const activeOpties = OPTIES.filter(o => o.tab === 's12' || o.tab === 's34' || o.tab === 's56');
  const byAE = {};
  activeOpties.forEach(o => {
    if(!byAE[o.ae]) byAE[o.ae] = {count:0, total:0};
    byAE[o.ae].count++;
    byAE[o.ae].total += o.amt;
  });
  const sorted = Object.entries(byAE).sort((a,b) => b[1].total - a[1].total);
  const maxAmt = sorted[0]?.[1].total || 1;

  document.getElementById('aeBreakdown').innerHTML = sorted.map(([ae, {count, total}]) => {
    const s = AE_STYLES[ae] || {};
    const pct = Math.round((total/maxAmt)*100);
    return `<div style="display:flex;align-items:center;gap:8px;cursor:pointer" onclick="setAEFilter('${ae}',null)">
      <div class="ae-dot" style="background:${s.bg};color:${s.color};flex-shrink:0">${ae.slice(0,2)}</div>
      <div style="flex:1;min-width:0">
        <div style="display:flex;justify-content:space-between;margin-bottom:3px">
          <span style="font-size:11px;font-weight:600;color:var(--s700)">${ae}</span>
          <span style="font-size:11px;font-family:'DM Mono',monospace;color:var(--s600)">${fmtAmt(total)}</span>
        </div>
        <div style="height:4px;background:var(--s100);border-radius:4px;overflow:hidden">
          <div style="height:100%;width:${pct}%;background:${s.color};border-radius:4px"></div>
