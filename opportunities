<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;}
:root{
  --ink:#032D42;--ink-nav:#01161f;--ink-mid:#043d5a;
  --wasabi:#63DF4E;--wdk:#4ab83a;
  --white:#fff;--bg:#f1f5f9;
  --s50:#f8fafc;--s100:#f1f5f9;--s200:#e2e8f0;--s300:#cbd5e1;
  --s400:#94a3b8;--s500:#64748b;--s600:#475569;--s700:#334155;
  --s800:#1e293b;--s900:#0f172a;
  --b50:#eff6ff;--b100:#dbeafe;--b500:#3b82f6;--b600:#2563eb;
  --g50:#f0fdf4;--g100:#dcfce7;--g500:#22c55e;--g600:#16a34a;
  --a50:#fffbeb;--a100:#fef3c7;--a500:#f59e0b;--a600:#d97706;
  --r50:#fff1f2;--r100:#ffe4e6;--r500:#ef4444;--r600:#dc2626;
  --p50:#faf5ff;--p500:#a855f7;--p600:#9333ea;
  --sh-xs:0 1px 2px rgba(0,0,0,.05);
  --sh-sm:0 1px 3px rgba(0,0,0,.10),0 1px 2px rgba(0,0,0,.06);
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--s800);font-size:13px;line-height:1.5;}
a{text-decoration:none;color:inherit;}
button{font-family:inherit;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-thumb{background:var(--s300);border-radius:2px;}

/* NAV */
.gnav{height:44px;background:var(--ink-nav);display:flex;align-items:center;position:fixed;top:0;left:0;right:0;z-index:300;border-bottom:1px solid rgba(255,255,255,.06);}
.gnav-logo{display:flex;align-items:center;padding:0 14px;height:44px;border-right:1px solid rgba(255,255,255,.07);flex-shrink:0;}
.gnav-tabs{display:flex;align-items:center;}
.gnav-tab{display:flex;align-items:center;height:44px;padding:0 13px;font-size:12px;color:rgba(255,255,255,.5);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;text-decoration:none;}
.gnav-tab:hover{color:rgba(255,255,255,.8);background:rgba(255,255,255,.04);}
.gnav-pill-wrap{flex:1;display:flex;justify-content:center;}
.gnav-pill{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;padding:4px 12px;border-radius:20px;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.8);cursor:pointer;}
.gnav-pill-dot{width:6px;height:6px;border-radius:50%;background:var(--wasabi);}
.gnav-r{display:flex;align-items:center;gap:2px;padding:0 10px;}
.gnav-btn{width:30px;height:30px;display:flex;align-items:center;justify-content:center;border-radius:4px;color:rgba(255,255,255,.45);cursor:pointer;font-size:13px;border:none;background:transparent;}
.gnav-btn:hover{background:rgba(255,255,255,.07);color:rgba(255,255,255,.8);}
.gnav-av{width:28px;height:28px;background:var(--wasabi);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--ink);cursor:pointer;margin-left:4px;}

/* SIDEBAR */
.sbar{position:fixed;top:44px;left:0;bottom:0;width:44px;background:#0d1f2b;border-right:1px solid rgba(255,255,255,.05);z-index:200;display:flex;flex-direction:column;overflow:hidden;transition:width .22s cubic-bezier(.4,0,.2,1);}
.sbar:hover{width:180px;box-shadow:4px 0 20px rgba(0,0,0,.25);}
.sbar::-webkit-scrollbar{width:0;}
.sbar-sec{padding:10px 0 4px;}
.sbar-lbl{font-size:9px;font-weight:700;letter-spacing:.10em;text-transform:uppercase;color:rgba(255,255,255,.20);padding:0 14px;margin-bottom:2px;display:block;white-space:nowrap;opacity:0;transition:opacity .15s .05s;}
.sbar:hover .sbar-lbl{opacity:1;}
.sbar-item{display:flex;align-items:center;gap:10px;padding:8px 14px;font-size:12px;color:rgba(255,255,255,.50);border-left:2px solid transparent;transition:background .12s,color .12s;text-decoration:none;white-space:nowrap;}
.sbar-item:hover{background:rgba(255,255,255,.05);color:rgba(255,255,255,.85);}
.sbar-item.on{color:var(--wasabi);border-left-color:var(--wasabi);background:rgba(99,223,78,.06);font-weight:500;}
.sbar-ic{width:16px;min-width:16px;text-align:center;font-size:15px;flex-shrink:0;}
.sbar-item.on .sbar-ic::after{content:'';display:block;width:4px;height:4px;border-radius:50%;background:var(--wasabi);margin:1px auto 0;}
.sbar:hover .sbar-item.on .sbar-ic::after{display:none;}
.sb{margin-left:auto;font-size:9px;font-weight:600;padding:1px 5px;border-radius:8px;background:rgba(255,255,255,.08);color:rgba(255,255,255,.40);opacity:0;transition:opacity .1s;flex-shrink:0;}
.sbar:hover .sb{opacity:1;}
.sb.r{background:rgba(239,68,68,.20);color:#fca5a5;}
.sdiv{height:1px;background:rgba(255,255,255,.06);margin:5px 10px;}
.sbar-footer{padding:8px 14px 10px;font-size:9px;color:rgba(255,255,255,.14);margin-top:auto;white-space:nowrap;opacity:0;transition:opacity .15s;}
.sbar:hover .sbar-footer{opacity:1;}

/* LAYOUT */
.main{margin-top:44px;margin-left:44px;min-height:calc(100vh - 44px);display:flex;flex-direction:column;}
.page-hdr{background:var(--white);border-bottom:1px solid var(--s200);padding:18px 24px 0;position:sticky;top:44px;z-index:100;}
.phdr-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;}
.phdr-date{font-size:11px;color:var(--s400);margin-bottom:2px;}
.phdr-name{font-size:22px;font-weight:700;color:var(--s900);letter-spacing:-.02em;}
.phdr-sub{font-size:12px;color:var(--s500);}
.phdr-acts{display:flex;align-items:center;gap:7px;flex-shrink:0;}
.page-body{display:flex;flex:1;min-height:0;}
.body-main{flex:1;padding:16px 22px 48px;display:flex;flex-direction:column;gap:14px;min-width:0;}
.body-side{width:268px;flex-shrink:0;border-left:1px solid var(--s200);background:var(--white);padding:14px 15px;display:flex;flex-direction:column;gap:14px;overflow-y:auto;position:sticky;top:calc(44px + 170px);max-height:calc(100vh - 44px - 170px);align-self:flex-start;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;font-family:inherit;font-size:12px;font-weight:500;padding:6px 13px;border-radius:6px;cursor:pointer;border:1px solid;transition:.12s;white-space:nowrap;text-decoration:none;}
.btn-g{background:transparent;color:var(--s600);border-color:var(--s200);}
.btn-g:hover{background:var(--s50);border-color:var(--s300);}
.btn-p{background:var(--ink);color:var(--white);border-color:var(--ink);}
.btn-p:hover{background:var(--ink-mid);}
.btn-w{background:var(--wasabi);color:var(--ink);border-color:var(--wasabi);font-weight:600;}
.btn-sm{font-size:11px;padding:5px 11px;}
.btn-xs{font-size:10px;padding:3px 8px;}

/* STAT CARDS */
.stat-row{display:flex;gap:8px;margin-bottom:4px;}
.stat-card{flex:1;background:var(--white);border:1px solid var(--s200);border-radius:10px;padding:11px 13px;cursor:default;box-shadow:var(--sh-xs);}
.stat-lbl{font-size:11px;color:var(--s500);margin-bottom:2px;font-weight:500;}
.stat-val{font-size:20px;font-weight:700;color:var(--s900);line-height:1;margin-bottom:2px;font-family:'DM Mono',monospace;}
.stat-val.red{color:var(--r600);}
.stat-d{font-size:11px;color:var(--s400);}
.du{color:var(--g600);font-weight:600;}
.dw{color:var(--a600);font-weight:600;font-size:10px;}

/* STAGE TABS */
.stage-tabs{display:flex;gap:0;border-bottom:2px solid var(--s200);margin-bottom:0;}
.stab{padding:9px 14px;font-size:12px;font-weight:500;color:var(--s500);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;white-space:nowrap;display:flex;align-items:center;gap:6px;border:none;background:none;}
.stab:hover{color:var(--s800);}
.stab.on{color:var(--ink);border-bottom-color:var(--ink);font-weight:600;}
.stab .cnt{font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;background:var(--s100);color:var(--s500);}
.stab.on .cnt{background:rgba(3,45,66,.1);color:var(--ink);}
.stab.won .cnt{background:rgba(22,163,74,.12);color:var(--g600);}
.stab.won.on{color:var(--g600);border-bottom-color:var(--g600);}
.stab.lost .cnt{background:rgba(220,38,38,.1);color:var(--r600);}
.stab.lost.on{color:var(--r600);border-bottom-color:var(--r600);}
.stab.nd .cnt{background:rgba(148,163,184,.15);color:var(--s500);}

/* FILTER BAR */
.filter-bar{display:flex;align-items:center;gap:8px;padding:10px 0 4px;flex-wrap:wrap;}
.filter-search{position:relative;flex:1;min-width:180px;max-width:280px;}
.filter-search input{width:100%;padding:7px 10px 7px 30px;border:1px solid var(--s200);border-radius:7px;font-size:12px;font-family:inherit;background:var(--white);color:var(--s800);}
.filter-search input:focus{outline:none;border-color:var(--s400);}
.filter-search svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);width:13px;height:13px;color:var(--s400);}
.filter-chip{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:500;padding:5px 11px;border-radius:20px;border:1px solid var(--s200);background:var(--white);cursor:pointer;color:var(--s600);}
.filter-chip:hover{border-color:var(--s300);background:var(--s50);}
.filter-chip.on{background:var(--ink);color:var(--white);border-color:var(--ink);}
.filter-total{margin-left:auto;font-size:12px;color:var(--s400);}

/* TABLE */
.opty-table-wrap{background:var(--white);border:1px solid var(--s200);border-radius:10px;overflow:hidden;box-shadow:var(--sh-xs);}
.opty-table{width:100%;border-collapse:collapse;}
.opty-table th{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--s400);padding:9px 12px;text-align:left;border-bottom:1px solid var(--s200);background:var(--s50);white-space:nowrap;cursor:pointer;user-select:none;}
.opty-table th:hover{color:var(--s700);}
.opty-table th .sort{font-size:9px;opacity:.4;margin-left:3px;}
.opty-table td{padding:10px 12px;border-bottom:1px solid var(--s100);vertical-align:middle;font-size:12px;}
.opty-table tr:last-child td{border-bottom:none;}
.opty-table tr:hover td{background:var(--s50);}
.opty-table tr.clickable{cursor:pointer;}

/* OPTY ID */
.opty-id{font-family:'DM Mono',monospace;font-size:10px;color:var(--b600);font-weight:500;cursor:pointer;}
.opty-id:hover{text-decoration:underline;}
.opty-name{font-weight:600;color:var(--s800);margin-bottom:1px;}
.opty-product{font-size:11px;color:var(--s500);}

/* AE BUBBLE */
.ae-dot{width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;flex-shrink:0;}

/* STAGE PILL */
.spill{display:inline-flex;align-items:center;font-size:10px;font-weight:600;padding:2px 8px;border-radius:10px;white-space:nowrap;}
.s1{background:#eff6ff;color:#1d4ed8;}
.s2{background:#f0fdf4;color:#15803d;}
.s3{background:#fefce8;color:#854d0e;}
.s4{background:#faf5ff;color:#7e22ce;}
.s5{background:rgba(251,146,60,.12);color:#c2410c;}
.s6{background:rgba(6,182,212,.12);color:#0e7490;}
.sw{background:rgba(22,163,74,.12);color:#15803d;border:1px solid rgba(22,163,74,.25);}
.sl{background:rgba(220,38,38,.1);color:#dc2626;border:1px solid rgba(220,38,38,.2);}
.sn{background:var(--s100);color:var(--s500);border:1px solid var(--s200);}

/* AMOUNT */
.amt{font-family:'DM Mono',monospace;font-size:12px;font-weight:600;color:var(--s900);}
.amt-small{font-size:11px;color:var(--s500);font-weight:400;}

/* BDR ROLE */
.bdr-tag{display:inline-flex;align-items:center;font-size:10px;font-weight:600;padding:2px 7px;border-radius:8px;}
.bdr-src{background:rgba(99,223,78,.15);color:#166534;}
.bdr-co{background:rgba(59,130,246,.12);color:#1d4ed8;}
.bdr-ast{background:rgba(148,163,184,.12);color:var(--s600);}

/* CLOSE DATE */
.cdate{font-size:11px;color:var(--s600);}
.cdate.overdue{color:var(--r600);font-weight:600;}
.cdate.soon{color:var(--a600);font-weight:600;}

/* SIDE PANEL */
.side-hd{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--s400);margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;}
.side-link{font-size:11px;color:var(--b600);cursor:pointer;}

/* OPTY UPDATE CARD */
.opu-card{background:var(--white);border:1px solid var(--s200);border-radius:8px;padding:11px 12px;cursor:pointer;transition:.12s;}
.opu-card:hover{border-color:var(--s300);box-shadow:var(--sh-xs);}
.opu-chip{display:inline-flex;align-items:center;font-size:9px;font-weight:700;font-family:'DM Mono',monospace;padding:2px 7px;border-radius:6px;background:rgba(3,45,66,.07);color:var(--ink);margin-bottom:5px;}
.opu-title{font-size:12px;font-weight:600;color:var(--s800);margin-bottom:2px;}
.opu-product{font-size:11px;color:var(--s500);margin-bottom:6px;}
.opu-body{font-size:11px;color:var(--s600);line-height:1.55;display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden;-webkit-line-clamp:3;}
.opu-body.expanded{-webkit-line-clamp:unset;}
.opu-foot{display:flex;align-items:center;justify-content:space-between;margin-top:7px;}
.opu-meta{font-size:10px;color:var(--s400);}
.opu-expand{font-size:10px;color:var(--b600);cursor:pointer;}

/* MODAL */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.45);display:flex;align-items:center;justify-content:center;z-index:999;backdrop-filter:blur(3px);}
.modal{background:var(--white);border-radius:12px;width:min(640px,96vw);max-height:88vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2);}
.modal-hd{padding:16px 20px;border-bottom:1px solid var(--s200);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--white);z-index:2;}
.modal-title{font-size:15px;font-weight:700;color:var(--s900);}
.modal-close{width:28px;height:28px;border-radius:50%;background:var(--s100);border:none;color:var(--s500);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;}
.modal-body{padding:20px;}

/* EMPTY STATE */
.empty{text-align:center;padding:60px 20px;color:var(--s400);}
.empty-icon{font-size:40px;margin-bottom:12px;}
.empty-msg{font-size:14px;font-weight:500;color:var(--s500);margin-bottom:6px;}
.empty-sub{font-size:12px;}

/* PROGRESS BAR */
.prog-wrap{width:80px;background:var(--s200);border-radius:4px;height:4px;overflow:hidden;display:inline-block;vertical-align:middle;}
.prog-fill{height:100%;border-radius:4px;}

@keyframes fadeIn{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:translateY(0);}}
.fade-in{animation:fadeIn .18s ease;}
</style>
</head>
