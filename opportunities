function stagePill(stage, stageN) {
  const MAP = {1:'s1',2:'s2',3:'s3',4:'s4',5:'s5',6:'s6',7:'sw',8:'sl',9:'sn'};
  return `<span class="spill ${MAP[stageN]||'sn'}">${stage}</span>`;
}

function bdrTag(role) {
  const map = {'Source':'bdr-src','Co-Source':'bdr-co','Assist':'bdr-ast'};
  return `<span class="bdr-tag ${map[role]||'bdr-ast'}">${role}</span>`;
}

function fmtAmt(n) {
  if(n >= 1000000) return '$' + (n/1000000).toFixed(1) + 'M';
  if(n >= 1000) return '$' + Math.round(n/1000) + 'K';
  return '$' + n;
}

function fmtClose(dateStr, tab) {
  if(tab === 'won' || tab === 'lost' || tab === 'nd') return `<span class="cdate">${new Date(dateStr+'T12:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</span>`;
  const d = new Date(dateStr+'T12:00');
  const now = new Date();
  const days = Math.ceil((d - now) / 864e5);
  const label = d.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  if(days < 0)   return `<span class="cdate overdue">${label} · Overdue</span>`;
  if(days <= 14) return `<span class="cdate soon">${label} · ${days}d</span>`;
  return `<span class="cdate">${label}</span>`;
}

function aeBubble(ae) {
  const s = AE_STYLES[ae] || {bg:'rgba(100,116,139,.1)',color:'#475569'};
  return `<div class="ae-dot" style="background:${s.bg};color:${s.color}" title="${ae} (AE)">${ae.slice(0,2).toUpperCase()}</div>`;
}

function progressBar(stage) {
  const pct = Math.min(Math.round((stage/6)*100), 100);
  const col = stage <= 2 ? '#3b82f6' : stage <= 4 ? '#f59e0b' : '#22c55e';
  return `<div class="prog-wrap"><div class="prog-fill" style="width:${pct}%;background:${col}"></div></div>`;
}

