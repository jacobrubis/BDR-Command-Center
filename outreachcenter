function openAdd1on1(){const aeOpts=AES.map(ae=>`<option value="${ae.id}">${ae.name}</option>`).join('');showModal('Add 1:1 Note',`<div class="form-2"><div class="form-row"><label class="form-label">Date</label><input type="date" class="form-input" id="m-od" value="${today()}"></div><div class="form-row"><label class="form-label">AE *</label><select class="form-select" id="m-oae">${aeOpts}</select></div></div><div class="form-row"><label class="form-label">Notes</label><textarea class="form-textarea" id="m-ob" style="min-height:90px" placeholder="What was discussed…"></textarea></div><div class="form-row"><label class="form-label">Action Items <span style="font-weight:400;text-transform:none;letter-spacing:0;color:var(--text3)">— auto-creates tasks</span></label><div id="action-items-list"><div style="display:flex;gap:6px"><span style="color:var(--sn-blue);font-weight:700;flex-shrink:0;margin-top:8px">→</span><input class="form-input action-item-input" placeholder="Action item…" style="flex:1"></div></div><button type="button" class="btn btn-ghost btn-sm" style="margin-top:7px" onclick="addAIRow()">+ Add another</button></div><div class="form-row"><label class="form-label">Pinned Note</label><input class="form-input pinned-note-input" placeholder="Important context to keep top of mind…"></div>`,()=>{const aeId=document.getElementById('m-oae').value;const body=document.getElementById('m-ob').value.trim();const actionItems=[...document.querySelectorAll('.action-item-input')].map(i=>i.value.trim()).filter(Boolean);const pinnedNote=document.querySelector('.pinned-note-input')?.value.trim()||'';if(!body&&!actionItems.length&&!pinnedNote){toast('Add at least a note or action item');return;}S.oneons[aeId].unshift({id:uid(),date:document.getElementById('m-od').value,body,actionItems,pinnedNote});saveOneons();if(actionItems.length){if(!S.todos[aeId])S.todos[aeId]=[];actionItems.forEach(item=>{S.todos[aeId].push({id:uid(),label:item,due:'',priority:'Med',account:'',done:false,_from1on1:true,_aeId:aeId,_aeName:aeById(aeId)?.name.split(' ')[0]||''});});saveTodos();}if(pinnedNote){if(!S.notes[aeId])S.notes[aeId]=[];S.notes[aeId].push({id:uid(),date:document.getElementById('m-od').value,author:'Jacob',text:pinnedNote});saveNotes();}closeModal();renderPage('1:1 note added');toast('1:1 saved'+(actionItems.length?' · '+actionItems.length+' task'+(actionItems.length!==1?'s':'')+' created':''),'ok');});}
