function showUndoBar(label,snap,seconds){const existing=document.getElementById('undo-bar');if(existing)existing.remove();if(window._undoTimer)clearInterval(window._undoTimer);window._undoSnapshot=snap;const bar=document.createElement('div');bar.id='undo-bar';bar.style.cssText='position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;align-items:center;gap:10px;padding:10px 14px;background:#032D42;color:#fff;border-radius:5px;box-shadow:0 4px 20px rgba(3,45,66,0.3);font-size:12px;';bar.innerHTML=`<span style="opacity:.85">${label}</span><span id="undo-timer" style="font-size:11px;opacity:.55;min-width:18px;text-align:center">${seconds}s</span><button onclick="applyUndo()" style="padding:4px 12px;background:#63DF4E;color:#032D42;border:none;border-radius:5px;font-size:11px;font-weight:700;cursor:pointer">Undo</button>`;document.body.appendChild(bar);let remaining=seconds;window._undoTimer=setInterval(()=>{remaining--;const el=document.getElementById('undo-timer');if(el)el.textContent=remaining+'s';if(remaining<=0){clearInterval(window._undoTimer);document.getElementById('undo-bar')?.remove();window._undoSnapshot=null;}},1000);}
function applyUndo(){if(!window._undoSnapshot)return;try{const prev=JSON.parse(window._undoSnapshot);if(prev.campaigns)S.campaigns=prev.campaigns;if(prev.accounts)S.accounts=prev.accounts;if(prev.todos)S.todos=prev.todos;if(prev.notes)S.notes=prev.notes;if(prev.oneons)S.oneons=prev.oneons;if(prev.links)S.links=prev.links;if(prev.events)S.events=prev.events;if(prev.wins)S.wins=prev.wins;if(prev.activity)S.activity=prev.activity;markDirty('bdr2_camps','bdr2_emails','bdr2_accounts','bdr2_todos','bdr2_notes','bdr2_oneons','bdr2_links','bdr2_events','bdr2_wins','bdr2_activity');saveAll();renderPage();clearInterval(window._undoTimer);document.getElementById('undo-bar')?.remove();window._undoSnapshot=null;toast('Undone','ok');}catch(e){toast('Undo failed');}}
function undoReset(){applyUndo();}
function withUndo(label,fn){window._undoSnap=snapshotState();fn();if(window._undoSnap){showUndoBar(label,window._undoSnap,5);window._undoSnap=null;}}

