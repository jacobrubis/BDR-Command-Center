// ── LINKS ─────────────────────────────────────────────────────────────────
let linksAEF='all';
function renderLinks(){linksAEF=filterAE;const all=linksAEF==='all'?AES.flatMap(ae=>(S.links[ae.id]||[]).map(l=>({...l,_ae:ae}))):(S.links[linksAEF]||[]).map(l=>({...l,_ae:aeById(linksAEF)}));let html=`<div class="page-hd"><div><div class="page-title">Quick Links</div><div class="page-sub">${all.length} links saved</div></div><div class="hd-acts"><button class="btn btn-primary btn-sm" onclick="openAddLink()">+ Add Link</button></div></div>${aeTabs(linksAEF,'setLinksAEF')}`;if(!all.length)return html+`<div class="card"><div class="card-body"><div style="text-align:center;padding:30px;color:var(--text3);font-size:12px">No links yet. Add account plans, research docs, etc.</div></div></div>`;const byTag={};all.forEach(l=>{const t=l.account||'General';if(!byTag[t])byTag[t]=[];byTag[t].push(l);});Object.entries(byTag).forEach(([tag,lnks])=>{html+=`<div class="card"><div class="card-head card-head-accent"><span>🔗</span><div class="card-title">${tag}</div></div><div class="card-body"><div class="link-grid">${lnks.map(l=>`<div class="link-card" onclick="window.open('${l.url}','_blank')"><div style="font-size:13px;font-weight:600;color:var(--sn-blue)">${l.name}</div><div style="font-size:10px;color:var(--text3);margin-top:2px">${l.type}${l._ae?' · '+l._ae.name.split(' ')[0]:''}</div><div style="display:flex;justify-content:flex-end;margin-top:6px"><div class="btn-icon del" onclick="event.stopPropagation();delLink('${l._ae?.id}','${l.id}')">×</div></div></div>`).join('')}</div></div></div>`;});return html;}
function setLinksAEF(id){linksAEF=id;filterAE=id;renderPage();}
function openAddLink(){const aeOpts=AES.map(ae=>`<option value="${ae.id}"${ae.id===(linksAEF==='all'?AES[0].id:linksAEF)?' selected':''}>${ae.name}</option>`).join('');showModal('Add Quick Link',`<div class="form-row"><label class="form-label">Name *</label><input class="form-input" id="m-ln" placeholder="Hub Group Account Research"></div><div class="form-row"><label class="form-label">URL *</label><input class="form-input" id="m-lu" placeholder="https://…"></div><div class="form-2"><div class="form-row"><label class="form-label">Account / Group</label><input class="form-input" id="m-la" placeholder="Hub Group"></div><div class="form-row"><label class="form-label">Type</label><select class="form-select" id="m-lt">${LINK_TYPES.map(t=>`<option>${t}</option>`).join('')}</select></div></div><div class="form-row"><label class="form-label">AE</label><select class="form-select" id="m-lae">${aeOpts}</select></div>`,()=>{const name=document.getElementById('m-ln').value.trim(),url=document.getElementById('m-lu').value.trim();if(!name||!url){toast('Name and URL required');return;}const aeId=document.getElementById('m-lae').value;S.links[aeId].push({id:uid(),name,url,account:document.getElementById('m-la').value||'General',type:document.getElementById('m-lt').value});saveLinks();closeModal();renderPage();toast('Link added','ok');});}
function delLink(aeId,id){S.links[aeId]=(S.links[aeId]||[]).filter(x=>x.id!==id);saveLinks();renderPage();}

// ── EVENTS ────────────────────────────────────────────────────────────────
function renderEvents(){const evts=(S.events||[]).sort((a,b)=>a.date.localeCompare(b.date));const upcoming=evts.filter(e=>e.date>=today());const past=evts.filter(e=>e.date<today());let html=`<div class="page-hd"><div><div class="page-title">Events</div><div class="page-sub">${upcoming.length} upcoming · ${past.length} past</div></div><div class="hd-acts"><button class="btn btn-primary btn-sm" onclick="openAddEvent()">+ Add Event</button></div></div>`;if(!evts.length)return html+`<div class="card"><div class="card-body"><div style="text-align:center;padding:30px;color:var(--text3);font-size:12px">No events yet. Add marketing events, webinars, and field events.</div></div></div>`;if(upcoming.length){html+=`<div class="card" style="margin-bottom:14px"><div class="card-head card-head-accent"><span>📅</span><div class="card-title">Upcoming (${upcoming.length})</div></div><div class="card-body">`;upcoming.forEach((e,i)=>{html+=eventRow(e,false);});html+=`</div></div>`;}if(past.length){html+=`<div class="card"><div class="card-head card-head-accent"><span>✓</span><div class="card-title" style="color:var(--text3)">Past (${past.length})</div></div><div class="card-body">`;past.slice(-10).reverse().forEach((e,i)=>{html+=eventRow(e,true);});html+=`</div></div>`;}return html;}
function eventRow(e,past){const daysUntil=!past?Math.ceil((new Date(e.date+'T12:00:00')-new Date())/864e5):null;const urgency=daysUntil!==null&&daysUntil<=7?'var(--red)':daysUntil!==null&&daysUntil<=14?'var(--amber)':'var(--sn-blue)';return `<div class="crow" style="align-items:flex-start;padding:11px 0;opacity:${past?'0.6':'1'}"><div style="min-width:52px;text-align:center;padding-top:2px"><div style="font-size:18px;font-weight:700;color:${urgency}">${new Date(e.date+'T12:00:00').getDate()}</div><div style="font-size:10px;color:var(--text3)">${new Date(e.date+'T12:00:00').toLocaleDateString('en-US',{month:'short'})}</div></div><div style="flex:1;min-width:0;padding-left:10px"><div style="font-size:13px;font-weight:600;color:var(--sn-blue)">${e.url?`<a href="${e.url}" target="_blank" style="color:var(--sn-blue);text-decoration:none">${e.title} ↗</a>`:e.title}</div><div style="font-size:11px;color:var(--text2);margin-top:3px">${e.virtual?'💻 Virtual':'📍 '+e.location}</div>${!past&&daysUntil!==null?`<div style="font-size:10px;color:${urgency};margin-top:3px;font-weight:600">${daysUntil===0?'Today':daysUntil===1?'Tomorrow':daysUntil+' days away'}</div>`:''}</div><div style="display:flex;gap:5px"><div class="btn-icon" onclick="editEvent('${e.id}')">✎</div><div class="btn-icon del" onclick="deleteEvent('${e.id}')">×</div></div></div>`;}
function openAddEvent(){showModal('Add Event',`<div class="form-row"><label class="form-label">Event Title *</label><input class="form-input" id="e-title" placeholder="ServiceNow World Forum Chicago"></div><div class="form-2"><div class="form-row"><label class="form-label">Date *</label><input type="date" class="form-input" id="e-date" value="${today()}"></div><div class="form-row"><label class="form-label">Industry</label><input class="form-input" id="e-ind" placeholder="Healthcare, Finance…"></div></div><div class="form-row"><label class="form-label">Location</label><div style="display:flex;gap:8px;align-items:center;margin-top:4px"><label class="cb-row"><input type="checkbox" id="e-virt"><span>Virtual</span></label><input class="form-input" id="e-loc" placeholder="Chicago, IL" style="flex:1"></div></div><div class="form-row"><label class="form-label">Link</label><input class="form-input" id="e-url" placeholder="https://…"></div><div class="form-row"><label class="form-label">Notes</label><textarea class="form-textarea" id="e-notes" style="min-height:60px"></textarea></div>`,()=>{const title=document.getElementById('e-title').value.trim();const date=document.getElementById('e-date').value;if(!title||!date){toast('Title and date required');return;}if(!S.events)S.events=[];S.events.push({id:uid(),title,date,industry:document.getElementById('e-ind').value,virtual:document.getElementById('e-virt').checked,location:document.getElementById('e-loc').value,url:document.getElementById('e-url').value,notes:document.getElementById('e-notes').value});saveEvents();closeModal();renderPage();toast('Event added','ok');});}
function editEvent(id){const e=(S.events||[]).find(x=>x.id===id);if(!e)return;showModal('Edit Event',`<div class="form-row"><label class="form-label">Title</label><input class="form-input" id="e-title" value="${e.title}"></div><div class="form-2"><div class="form-row"><label class="form-label">Date</label><input type="date" class="form-input" id="e-date" value="${e.date}"></div><div class="form-row"><label class="form-label">Industry</label><input class="form-input" id="e-ind" value="${e.industry||''}"></div></div><div class="form-row"><label class="form-label">Location</label><div style="display:flex;gap:8px;align-items:center;margin-top:4px"><label class="cb-row"><input type="checkbox" id="e-virt" ${e.virtual?'checked':''}><span>Virtual</span></label><input class="form-input" id="e-loc" value="${e.location||''}" style="flex:1"></div></div><div class="form-row"><label class="form-label">Link</label><input class="form-input" id="e-url" value="${e.url||''}"></div><div class="form-row"><label class="form-label">Notes</label><textarea class="form-textarea" id="e-notes" style="min-height:60px">${e.notes||''}</textarea></div>`,()=>{e.title=document.getElementById('e-title').value.trim();e.date=document.getElementById('e-date').value;e.industry=document.getElementById('e-ind').value;e.virtual=document.getElementById('e-virt').checked;e.location=document.getElementById('e-loc').value;e.url=document.getElementById('e-url').value;e.notes=document.getElementById('e-notes').value;saveEvents();closeModal();renderPage();toast('Updated','ok');});}
function deleteEvent(id){S.events=S.events.filter(x=>x.id!==id);saveEvents();renderPage();}

// ── RECAP ─────────────────────────────────────────────────────────────────
function renderRecap(){const now=new Date();const firstOfMonth=new Date(now.getFullYear(),now.getMonth(),1).toISOString().slice(0,10);const lastOfMonth=new Date(now.getFullYear(),now.getMonth()+1,0).toISOString().slice(0,10);return `<div class="page-hd"><div><div class="page-title">Recap</div><div class="page-sub">Campaign and account activity summary by date range</div></div></div><div class="card" style="margin-bottom:16px"><div class="card-body" style="display:flex;align-items:center;gap:12px;flex-wrap:wrap"><div style="display:flex;align-items:center;gap:8px"><label class="form-label" style="margin:0">From</label><input type="date" id="recap-from" class="form-input" value="${firstOfMonth}" style="width:150px"><label class="form-label" style="margin:0">To</label><input type="date" id="recap-to" class="form-input" value="${lastOfMonth}" style="width:150px"></div><div style="display:flex;gap:6px"><button class="btn btn-ghost btn-sm" onclick="setRecapRange('month')">This Month</button><button class="btn btn-ghost btn-sm" onclick="setRecapRange('lastmonth')">Last Month</button><button class="btn btn-ghost btn-sm" onclick="setRecapRange('q')">This Quarter</button><button class="btn btn-ghost btn-sm" onclick="buildRecapOutput()">Build Report</button></div></div></div><div id="recap-body">${buildRecapBody(firstOfMonth,lastOfMonth)}</div>`;}
function setRecapRange(preset){const now=new Date();let from,to;if(preset==='month'){from=new Date(now.getFullYear(),now.getMonth(),1);to=new Date(now.getFullYear(),now.getMonth()+1,0);}else if(preset==='lastmonth'){from=new Date(now.getFullYear(),now.getMonth()-1,1);to=new Date(now.getFullYear(),now.getMonth(),0);}else if(preset==='q'){const q=Math.floor(now.getMonth()/3);from=new Date(now.getFullYear(),q*3,1);to=new Date(now.getFullYear(),q*3+3,0);}const fmt=d=>d.toISOString().slice(0,10);const f=document.getElementById('recap-from');const t=document.getElementById('recap-to');if(f)f.value=fmt(from);if(t)t.value=fmt(to);buildRecapOutput();}
function buildRecapOutput(){const from=document.getElementById('recap-from')?.value||'';const to=document.getElementById('recap-to')?.value||'';const el=document.getElementById('recap-body');if(el)el.innerHTML=buildRecapBody(from,to);}
function buildRecapBody(from,to){if(!from||!to)return '';const activeCamps=S.campaigns.filter(c=>Object.values(c.sentLog||{}).some(v=>v.date&&v.date>=from&&v.date<=to));if(!activeCamps.length)return `<div class="card"><div class="card-body"><div style="text-align:center;padding:30px;color:var(--text3);font-size:12px">No campaign activity in this range. Mark steps as sent in Campaigns to track here.</div></div></div>`;const totalContacts=activeCamps.reduce((s,c)=>s+c.contactCount,0);const totalMeetings=(S.wins||[]).filter(w=>w.date>=from&&w.date<=to).length;const totalPipeline=(S.wins||[]).filter(w=>w.date>=from&&w.date<=to).reduce((s,w)=>s+(parseFloat(w.pipeline)||0),0);let html=`<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px"><div class="kpi kpi-b"><div class="kpi-lbl">Campaigns</div><div class="kpi-val">${activeCamps.length}</div></div><div class="kpi kpi-g"><div class="kpi-lbl">Contacts Touched</div><div class="kpi-val">${totalContacts}</div></div><div class="kpi kpi-p"><div class="kpi-lbl">Meetings Booked</div><div class="kpi-val">${totalMeetings}</div></div><div class="kpi kpi-g"><div class="kpi-lbl">Pipeline</div><div class="kpi-val" style="font-size:${totalPipeline>=100000?'18px':'24px'}">${totalPipeline?'$'+totalPipeline.toLocaleString():'—'}</div></div></div><div class="card"><div class="card-head card-head-accent"><span>📣</span><div class="card-title">By Campaign</div></div><div class="card-body">`;activeCamps.forEach(c=>{const sentInRange=Object.entries(c.sentLog||{}).filter(([,v])=>v.date&&v.date>=from&&v.date<=to);const emailsInRange=sentInRange.length*(c.contactCount||0);const campWins=(S.wins||[]).filter(w=>w.campId===c.id&&w.date>=from&&w.date<=to);html+=`<div style="padding:12px 0;border-bottom:1px solid var(--border)"><div style="display:flex;align-items:flex-start;gap:10px;flex-wrap:wrap"><div style="flex:1"><div style="font-size:13px;font-weight:700;color:var(--sn-blue);margin-bottom:3px">${c.name}</div><div style="font-size:11px;color:var(--text3)">${c.product||''} · ${sentInRange.map(([s,v])=>`Step ${s} ${fmtDate(v.date)}`).join(' · ')}</div></div><div style="display:flex;gap:16px;text-align:center"><div><div style="font-size:18px;font-weight:700;color:var(--sn-blue)">${c.contactCount||0}</div><div style="font-size:10px;color:var(--text3)">contacts</div></div><div><div style="font-size:18px;font-weight:700;color:var(--sn-blue)">${emailsInRange}</div><div style="font-size:10px;color:var(--text3)">emails</div></div>${campWins.length?`<div><div style="font-size:18px;font-weight:700;color:#1a7a00">${campWins.length}</div><div style="font-size:10px;color:var(--text3)">meetings</div></div>`:''}</div></div></div>`;});html+=`</div></div>`;return html;}

// ── ACTIVITY ──────────────────────────────────────────────────────────────
function renderActivity(){const acts=[...(S.activity||[])].sort((a,b)=>b.date.localeCompare(a.date)||b.createdAt.localeCompare(a.createdAt));const fAEA=filterAE;const filtered=fAEA==='all'?acts:acts.filter(a=>a.aeId===fAEA);let html=`<div class="page-hd"><div><div class="page-title">Activity Log</div><div class="page-sub">${filtered.length} entries</div></div><div class="hd-acts"><button class="btn btn-primary btn-sm" onclick="openAddActivity()">+ Log Activity</button></div></div>${aeTabs(fAEA,'setActivityAEF')}`;if(!filtered.length)return html+`<div class="card"><div class="card-body"><div style="text-align:center;padding:40px;color:var(--text3);font-size:12px">No activity logged yet.<br><br><button class="btn btn-primary btn-sm" onclick="openAddActivity()">Log your first activity →</button></div></div></div>`;const byDate={};filtered.forEach(a=>{if(!byDate[a.date])byDate[a.date]=[];byDate[a.date].push(a);});Object.keys(byDate).sort((a,b)=>b.localeCompare(a)).forEach(date=>{html+=`<div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);padding:8px 0 5px">${fmtDateLong(date)}</div>`;byDate[date].forEach(a=>{const ae=aeById(a.aeId);const acct=S.accounts.find(x=>x.id===a.acctId);const camp=S.campaigns.find(x=>x.id===a.campId);const tColors={Calls:'#0369A1','LinkedIn Touches':'#0369A1','One Off Emails':'#1a7a00'};const color=tColors[a.type]||'var(--text3)';html+=`<div class="card" style="margin-bottom:6px"><div class="card-head" style="padding:10px 14px;border-left:3px solid ${color}"><div style="flex:1;min-width:0"><div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:3px"><span style="font-size:11px;font-weight:700;padding:1px 8px;border-radius:10px;background:${color}18;color:${color}">${a.type}</span>${acct?`<span style="font-size:12px;font-weight:600;color:var(--sn-blue)">${acct.name}</span>`:''} ${camp?`<span style="font-size:11px;color:var(--text3)">via ${camp.name}</span>`:''} ${ae?`<span style="font-size:10px;font-weight:600;padding:1px 6px;border-radius:10px;background:${ae.bg};color:${ae.color}">${ae.init}</span>`:''}</div><div style="font-size:12px;color:var(--text2);line-height:1.5">${a.note}</div></div><div class="btn-icon del" onclick="deleteActivity('${a.id}')">×</div></div></div>`;});});return html;}
function setActivityAEF(id){filterAE=id;renderPage();}
function openAddActivity(){const aeOpts=[...AES].sort((a,b)=>a.name.localeCompare(b.name)).map(ae=>`<option value="${ae.id}"${filterAE===ae.id?' selected':''}>${ae.name}</option>`).join('');const acctOpts=[...S.accounts].sort((a,b)=>a.name.localeCompare(b.name)).map(a=>`<option value="${a.id}">${a.name}</option>`).join('');const campOpts=[...S.campaigns].sort((a,b)=>a.name.localeCompare(b.name)).map(c=>`<option value="${c.id}">${c.name}</option>`).join('');showModal('Log Activity',`<div class="form-2"><div class="form-row"><label class="form-label">Type *</label><select class="form-select" id="act-type"><option>Calls</option><option>LinkedIn Touches</option><option>One Off Emails</option></select></div><div class="form-row"><label class="form-label">Date</label><input type="date" class="form-input" id="act-date" value="${today()}"></div></div><div class="form-row"><label class="form-label">Note *</label><textarea class="form-textarea" id="act-note" style="min-height:70px" placeholder="Called IT personas at Consilio about the Veza campaign…"></textarea></div><div class="form-2"><div class="form-row"><label class="form-label">Account</label><select class="form-select" id="act-acct"><option value="">— None —</option>${acctOpts}</select></div><div class="form-row"><label class="form-label">AE</label><select class="form-select" id="act-ae"><option value="">— None —</option>${aeOpts}</select></div></div><div class="form-row"><label class="form-label">Campaign</label><select class="form-select" id="act-camp"><option value="">— None —</option>${campOpts}</select></div>`,()=>{const note=document.getElementById('act-note').value.trim();if(!note){toast('Note required');return;}if(!S.activity)S.activity=[];S.activity.push({id:uid(),date:document.getElementById('act-date').value,createdAt:new Date().toISOString(),type:document.getElementById('act-type').value,note,acctId:document.getElementById('act-acct').value,aeId:document.getElementById('act-ae').value,campId:document.getElementById('act-camp').value});saveActivity();closeModal();renderPage('Activity logged');});}
function deleteActivity(id){withUndo('Activity deleted',()=>{S.activity=S.activity.filter(x=>x.id!==id);saveActivity();renderPage('Activity deleted');});}

// ── BIWEEKLY SUMMARY ──────────────────────────────────────────────────────
function renderSummaryPage(){const aeOpts=AES.map(ae=>`<option value="${ae.id}">${ae.name}</option>`).join('');const defFrom=new Date(Date.now()-14*864e5).toISOString().slice(0,10);return `<div class="page-hd"><div><div class="page-title">Biweekly Summary Generator</div><div class="page-sub">Build a 1:1-ready update for any AE</div></div></div><div class="card" style="margin-bottom:14px"><div class="card-head card-head-accent"><span>⚙️</span><div class="card-title">Configure Summary</div></div><div class="card-body"><div class="form-row"><label class="form-label">For which AE?</label><select class="form-select" id="sum-ae" style="max-width:280px">${aeOpts}</select></div><div class="form-row"><label class="form-label">Date Range</label><div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-top:6px"><div style="display:flex;align-items:center;gap:8px"><span style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase">From</span><input type="date" class="form-input" id="sum-from" value="${defFrom}" style="width:160px"><span style="font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase">To</span><input type="date" class="form-input" id="sum-to" value="${today()}" style="width:160px"></div><div style="display:flex;gap:6px"><button class="btn btn-ghost btn-sm" onclick="setSumRange(14)">Last 2 Weeks</button><button class="btn btn-ghost btn-sm" onclick="setSumRange(7)">Last Week</button><button class="btn btn-ghost btn-sm" onclick="setSumRange(0)">All Time</button></div></div></div><div class="form-row"><label class="form-label">Add context (optional)</label><textarea class="form-textarea" id="sum-ctx" placeholder="Upcoming events, blockers, asks for the AE…" style="min-height:60px"></textarea></div><button class="btn btn-primary" onclick="generateSummary()" id="sum-btn">Generate Summary →</button></div></div><div id="summary-result"></div>`;}
function setSumRange(days){const to=today();const from=days===0?'2020-01-01':new Date(Date.now()-days*864e5).toISOString().slice(0,10);const f=document.getElementById('sum-from');const t=document.getElementById('sum-to');if(f)f.value=from;if(t)t.value=to;}
async function generateSummary(){const aeId=document.getElementById('sum-ae').value;const fromDate=document.getElementById('sum-from')?.value||new Date(Date.now()-14*864e5).toISOString().slice(0,10);const toDate=document.getElementById('sum-to')?.value||today();const ctx=document.getElementById('sum-ctx')?.value?.trim()||'';const ae=aeById(aeId);if(!ae)return;const btn=document.getElementById('sum-btn');if(btn){btn.disabled=true;btn.textContent='Generating…';}const el=document.getElementById('summary-result');if(!el){if(btn){btn.disabled=false;btn.textContent='Generate Summary →';}return;}el.innerHTML=`<div class="card"><div class="card-body"><div style="display:flex;align-items:center;gap:10px;color:rgba(255,255,255,0.6);font-size:12px;background:var(--sn-blue);padding:20px;border-radius:var(--r)"><div style="width:16px;height:16px;border:2px solid rgba(99,223,78,0.3);border-top-color:#63DF4E;border-radius:50%;animation:spin .8s linear infinite"></div>Building summary for ${ae.name}…</div></div></div>`;const reset=()=>{if(btn){btn.disabled=false;btn.textContent='Generate Summary →';}};try{const aeCamps=S.campaigns.filter(c=>(c.aes||[]).includes(aeId));const aeAccts=S.accounts.filter(a=>a.aeId===aeId);const aeTodos=(S.todos[aeId]||[]);const aeWins=(S.wins||[]).filter(w=>w.aeId===aeId&&w.date>=fromDate);const recentOneons=(S.oneons[aeId]||[]).filter(o=>o.date>=fromDate).sort((a,b)=>b.date.localeCompare(a.date));const dataBlock=`AE: ${ae.name}\nPeriod: ${fromDate} to ${toDate}\n\nCAMPAIGNS:\n${aeCamps.map(c=>{const sentInRange=Object.entries(c.sentLog||{}).filter(([,v])=>v.date&&v.date>=fromDate&&v.date<=toDate);const recentEmails=sentInRange.length*(c.contactCount||0);return `${c.name} (${c.product||'no product'}): ${c.contactCount} contacts, ${Object.keys(c.sentLog||{}).length}/${c.totalSteps||5} steps, ${recentEmails} emails sent this period`;}).join('\n')||'No campaigns'}\n\nMEETINGS BOOKED (${aeWins.length}):\n${aeWins.map(w=>`${w.contactName}${w.contactTitle?' ('+w.contactTitle+')':''} at ${S.accounts.find(a=>a.id===w.acctId)?.name||'unknown'}${w.pipeline?' — $'+Number(w.pipeline).toLocaleString():''}`).join('\n')||'None'}\n\nACCOUNTS: ${aeAccts.length} total (${aeAccts.filter(a=>a.type==='customer').length} customers, ${aeAccts.filter(a=>a.type==='newlogo').length} new logos)\n\nTASKS OPEN: ${aeTodos.filter(t=>!t.done).length}\n\nRECENT 1:1 NOTES:\n${recentOneons.map(o=>`${o.date}: ${o.body}`).join('\n')||'None'}\n\nADDITIONAL CONTEXT: ${ctx||'None'}`;const resp=await Promise.race([fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:`You are helping Jacob Rubis, a BDR at ServiceNow, prepare a biweekly 1:1 update for an AE. Write a concise, direct summary the AE will actually read. Use ALL CAPS for section headers. Use bullet points starting with - for content. No filler. Sections: WHAT I DID FOR YOU, CAMPAIGNS STATUS, MEETINGS BOOKED, TASKS, WHAT I NEED FROM YOU, COMING UP.`,messages:[{role:'user',content:dataBlock}]})}),new Promise((_,rej)=>setTimeout(()=>rej(new Error('Timeout')),30000))]);if(!resp.ok)throw new Error('API '+resp.status);const data=await resp.json();const text=data.content?.map(b=>b.text||'').join('')||'';if(!text)throw new Error('Empty response');const formatted=text.replace(/^([A-Z][A-Z\s&:()—\-]{3,})$/gm,h=>`<div style="font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#63DF4E;margin-top:16px;margin-bottom:6px;border-top:1px solid rgba(99,223,78,0.2);padding-top:12px">${h.trim()}</div>`).replace(/^[\-•]\s+(.+)$/gm,'<div style="display:flex;gap:8px;margin:3px 0;font-size:13px;color:#fff;line-height:1.6"><span style="color:#63DF4E;flex-shrink:0">•</span><span>$1</span></div>').replace(/#{1,6}\s*/g,'').replace(/\*\*(.+?)\*\*/g,'$1').replace(/\n{2,}/g,'').replace(/\n/g,'');el.innerHTML=`<div class="card"><div class="card-head card-head-accent"><span>📋</span><div class="card-title">Summary — ${ae.name}</div><span class="pill pill-m">${fmtDate(fromDate)} – ${fmtDate(toDate)}</span><button class="btn btn-ghost btn-sm" onclick="copySummary()">Copy</button><button class="btn btn-primary btn-sm" onclick="generateSummary()">Regenerate</button></div><div class="card-body"><div style="background:var(--sn-blue);color:#fff;border-radius:var(--r);padding:20px;font-size:13px;line-height:1.8;font-family:var(--font)" id="summary-text">${formatted}</div></div></div>`;reset();}catch(e){el.innerHTML=`<div class="card"><div class="card-head card-head-accent"><span>⚠️</span><div class="card-title">AI unavailable — ${e.message}</div></div><div class="card-body"><div style="font-size:12px;color:var(--text2)">Check your network connection or try again. Your workspace data is intact.</div></div></div>`;reset();}}
function copySummary(){const el=document.getElementById('summary-text');if(!el)return;const text=el.innerText||el.textContent||'';navigator.clipboard.writeText(text).then(()=>toast('Copied to clipboard','ok')).catch(()=>{const ta=document.createElement('textarea');ta.value=text;ta.style.cssText='position:fixed;top:-9999px;left:-9999px;opacity:0';document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);toast('Copied','ok');});}

// ── QUICK ADD ─────────────────────────────────────────────────────────────
function openQuickAdd(){showModal('Quick Add',`<p style="font-size:12px;color:var(--text2);margin-bottom:12px">What do you want to add?</p><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><button class="btn btn-ghost" style="padding:13px;text-align:left" onclick="closeModal();openAddCampaign()">📣 New Campaign</button><button class="btn btn-ghost" style="padding:13px;text-align:left" onclick="closeModal();openAddAcct()">🏢 Account</button><button class="btn btn-ghost" style="padding:13px;text-align:left" onclick="closeModal();openAdd1on1()">🗓 1:1 Note</button><button class="btn btn-ghost" style="padding:13px;text-align:left" onclick="closeModal();openAddTodo()">✅ Task</button><button class="btn btn-ghost" style="padding:13px;text-align:left" onclick="closeModal();openAddNote()">📌 Important Note</button><button class="btn btn-ghost" style="padding:13px;text-align:left" onclick="closeModal();openAddWin()">🏆 Log Win</button></div>`,null,true);}

// ── MODAL / TOAST / SLIDE ─────────────────────────────────────────────────
function showModal(title,body,onSave,noSave,wide){document.getElementById('modal-root').innerHTML=`<div class="modal-bg" onclick="if(event.target===this)closeModal()"><div class="modal${wide?' wide':''}"><div class="modal-hd"><div class="modal-title">${title}</div><button class="modal-close" onclick="closeModal()">×</button></div><div class="modal-body">${body}</div>${!noSave?`<div class="modal-foot"><button class="btn btn-ghost" onclick="closeModal()">Cancel</button><button class="btn btn-primary" onclick="window._ms&&window._ms()">Save</button></div>`:''}</div></div>`;window._ms=onSave;}
function closeModal(){document.getElementById('modal-root').innerHTML='';window._ms=null;}
function closeSlide(){document.getElementById('slide').classList.remove('open');}
let _tt;function toast(msg,type){const el=document.getElementById('toast');if(!el)return;el.textContent=msg;el.className='toast'+(type==='ok'?' ok':'');setTimeout(()=>el.classList.add('show'),10);clearTimeout(_tt);_tt=setTimeout(()=>el.classList.remove('show'),2500);}

// ── EXPORT / IMPORT ───────────────────────────────────────────────────────
function exportData(){const json=JSON.stringify({_v:1,_exported:today(),_app:'BDR_AE_Workspace',...S},null,2);showModal('Export Data',`<div style="margin-bottom:10px;padding:9px 12px;background:var(--blue-dim);border-radius:var(--r2);font-size:11px;color:var(--sn-blue)">Copy all and save as <strong>BDR_Workspace_${today()}.json</strong>.</div><textarea id="export-ta" readonly style="width:100%;height:220px;font-family:var(--mono);font-size:10px;border:1px solid var(--border);border-radius:var(--r2);padding:8px;resize:vertical;color:var(--text2)"></textarea><div style="margin-top:8px"><button class="btn btn-primary btn-sm" onclick="document.getElementById('export-ta').select();document.execCommand('copy');toast('Copied','ok')">Copy All</button></div>`,null,true);setTimeout(()=>{const ta=document.getElementById('export-ta');if(ta){ta.value=json;ta.select();}},50);}
function importData(input){const file=input.files[0];if(!file)return;const reader=new FileReader();reader.onload=e=>{try{const data=JSON.parse(e.target.result);if(!data._app||data._app!=='BDR_AE_Workspace'){toast('Invalid file — must be a BDR Workspace export');return;}if(Array.isArray(data.campaigns))S.campaigns=data.campaigns;if(Array.isArray(data.accounts))S.accounts=data.accounts;if(data.todos)S.todos=data.todos;if(data.notes)S.notes=data.notes;if(data.oneons)S.oneons=data.oneons;if(data.links)S.links=data.links;if(Array.isArray(data.events))S.events=data.events;if(Array.isArray(data.wins))S.wins=data.wins;if(Array.isArray(data.activity))S.activity=data.activity;ensureAEData();markDirty('bdr2_camps','bdr2_emails','bdr2_accounts','bdr2_todos','bdr2_notes','bdr2_oneons','bdr2_links','bdr2_events','bdr2_wins');saveAll();renderPage();toast('✓ Imported '+S.campaigns.length+' campaigns, '+S.accounts.length+' accounts','ok');}catch(err){toast('Import failed: '+err.message);}};reader.readAsText(file);input.value='';}
function resetData(){if(!confirm('Delete ALL workspace data? This cannot be undone.\n\nExport a backup first if needed.'))return;const pw=prompt('Enter password to confirm reset:');if(pw!=='RESET'){toast('Incorrect — type RESET to confirm');return;}S.campaigns=[];S.accounts=[];S.wins=[];S.events=[];S.activity=[];AES.forEach(ae=>{S.todos[ae.id]=[];S.notes[ae.id]=[];S.oneons[ae.id]=[];S.links[ae.id]=[];});markDirty('bdr2_camps','bdr2_emails','bdr2_accounts','bdr2_todos','bdr2_notes','bdr2_oneons','bdr2_links','bdr2_events','bdr2_wins','bdr2_activity');saveAll();renderPage();toast('Workspace reset','ok');}

// ── INIT ──────────────────────────────────────────────────────────────────
async function init(){await loadAll();await seedIfEmpty();renderAEPods();renderPage();}
init();

</script>
