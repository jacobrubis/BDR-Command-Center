function toggleTodo(aeId,id){const t=(S.todos[aeId]||[]).find(x=>x.id===id);if(t){t.done=!t.done;saveTodos();renderPage(t.done?'Task done':'Task reopened');}}
function delTodo(aeId,id){withUndo('Task deleted',()=>{S.todos[aeId]=(S.todos[aeId]||[]).filter(x=>x.id!==id);saveTodos();renderPage('Task deleted');});}
function clearDone(){AES.forEach(ae=>{S.todos[ae.id]=(S.todos[ae.id]||[]).filter(t=>!t.done);});scheduleSave();renderPage();}
function openAddTodo(){const aeOpts=AES.map(ae=>`<option value="${ae.id}"${ae.id===(todoAEF==='all'||todoAEF==='general'?'':todoAEF)?' selected':''}>${ae.name}</option>`).join('');showModal('Add Task',`<div class="form-row"><label class="form-label">Task *</label><input class="form-input" id="m-tl" placeholder="What needs to happen?"></div><div class="form-row"><label class="form-label">Assign to AE</label><select class="form-select" id="m-tae"><option value="">— General —</option>${aeOpts}</select></div><div class="form-2"><div class="form-row"><label class="form-label">Due Date</label><input type="date" class="form-input" id="m-td" value="${today()}"></div><div class="form-row"><label class="form-label">Priority</label><select class="form-select" id="m-tp"><option>High</option><option selected>Med</option><option>Low</option></select></div></div>`,()=>{const label=document.getElementById('m-tl').value.trim();if(!label){toast('Required');return;}const aeId=document.getElementById('m-tae').value||'general';if(!S.todos[aeId])S.todos[aeId]=[];withUndo('Task added',()=>{S.todos[aeId].push({id:uid(),label,due:document.getElementById('m-td').value,priority:document.getElementById('m-tp').value,done:false,_aeId:aeId,_aeName:aeId==='general'?'General':aeById(aeId)?.name.split(' ')[0]||''});saveTodos();closeModal();renderPage('Task added');});});}

