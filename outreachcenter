function editWin(id){const w=S.wins?.find(x=>x.id===id);if(!w)return;const aeOpts=AES.map(ae=>`<option value="${ae.id}"${ae.id===w.aeId?' selected':''}>${ae.name}</option>`).join('');const acctOpts=[...S.accounts].sort((a,b)=>a.name.localeCompare(b.name)).map(a=>`<option value="${a.id}"${a.id===w.acctId?' selected':''}>${a.name}</option>`).join('');showModal('Edit Win',`<div class="form-row"><label class="form-label">Contact Name</label><input class="form-input" id="w-name" value="${w.contactName}"></div><div class="form-2"><div class="form-row"><label class="form-label">Account</label><select class="form-select" id="w-acct"><option value="">—</option>${acctOpts}</select></div><div class="form-row"><label class="form-label">AE</label><select class="form-select" id="w-ae">${aeOpts}</select></div></div><div class="form-row"><label class="form-label">Pipeline</label><input class="form-input" id="w-pipeline" value="${w.pipeline||''}"></div><div class="form-row"><label class="form-label">Notes</label><textarea class="form-textarea" id="w-notes">${w.notes||''}</textarea></div>`,()=>{w.contactName=document.getElementById('w-name').value;w.aeId=document.getElementById('w-ae').value;w.acctId=document.getElementById('w-acct').value;w.pipeline=document.getElementById('w-pipeline').value;w.notes=document.getElementById('w-notes').value;saveWins();closeModal();renderPage('Win updated');});}
function deleteWin(id){withUndo('Win deleted',()=>{S.wins=(S.wins||[]).filter(x=>x.id!==id);saveWins();renderPage('Win deleted');});}

// ── ACCOUNTS ──────────────────────────────────────────────────────────────
let acctAEF='all',acctTypeF='all',acctSearch='',acctBigBet=false;
