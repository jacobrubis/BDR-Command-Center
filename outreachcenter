async function loadAll(){
  const keys=[['camps','campaigns'],['accounts','accounts'],['todos','todos'],['notes','notes'],['oneons','oneons'],['links','links'],['events','events'],['wins','wins'],['activity','activity']];
  for(const [k,prop] of keys){
    try{const r=await window.storage.get('bdr2_'+k);if(r)S[prop]=JSON.parse(r.value);}
    catch(e){}
  }
  try{
    const er=await window.storage.get('bdr2_emails');
    if(er){const emailStore=JSON.parse(er.value);S.campaigns.forEach(c=>{if(emailStore[c.id])c.emails=emailStore[c.id];});}
  }catch(e){}
  S.campaigns.forEach(c=>{delete c.contacts;if(!c.emails)c.emails={};if(!c.stepCounts)c.stepCounts={};});
  if(!S.events)S.events=[];
  if(!S.wins)S.wins=[];
  if(!S.activity)S.activity=[];
  ensureAEData();
}

const _dirty=new Set();
function markDirty(...keys){keys.forEach(k=>_dirty.add(k));}

async function saveAll(){
  if(!_dirty.size){setSaveInd('● saved');return;}
  setSaveInd('saving…');
  const campsLite=S.campaigns.map(({emails:_e,...rest})=>rest);
  const emailStore={};
  S.campaigns.forEach(c=>{if(c.emails&&Object.keys(c.emails).length)emailStore[c.id]=c.emails;});
  const allPairs={
    bdr2_camps:campsLite,bdr2_emails:emailStore,bdr2_accounts:S.accounts,
    bdr2_todos:S.todos,bdr2_notes:S.notes,bdr2_oneons:S.oneons,
    bdr2_links:S.links,bdr2_events:S.events||[],bdr2_wins:S.wins||[],bdr2_activity:S.activity||[],
  };
  const toSave=[..._dirty].filter(k=>allPairs[k]);
  _dirty.clear();
  let errors=0;
  for(const key of toSave){
    try{await window.storage.set(key,JSON.stringify(allPairs[key]));}
    catch(e){errors++;_dirty.add(key);}
  }
  setSaveInd(errors===0?'● saved':'⚠ save error');
  if(errors)setTimeout(saveAll,3000);
}

