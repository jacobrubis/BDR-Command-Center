function isOverdue(d){return d&&d<today();}
function statusPill(s){const m={'Active':'pill-b','Paused':'pill-m','Responded':'pill-g','Converted':'pill-t','Complete':'pill-t','Bounced':'pill-r','Healthy':'pill-g','Expand':'pill-b','At Risk':'pill-r','Stalled':'pill-m','Research':'pill-p','In Motion':'pill-a','In Sequence':'pill-b','Meeting Booked':'pill-g','Closed Won':'pill-t'};return `<span class="pill ${m[s]||'pill-m'}">${s}</span>`;}
function priClass(p){return p==='High'?'pill-r':p==='Med'?'pill-a':'pill-m';}
function aeBubbles(ids){return (ids||[]).slice(0,4).map(id=>{const ae=aeById(id);return ae?`<div title="${ae.name}" style="width:18px;height:18px;border-radius:50%;background:${ae.bg};color:${ae.color};display:inline-flex;align-items:center;justify-content:center;font-size:7px;font-weight:700;border:1px solid rgba(3,45,66,0.15)">${ae.init.slice(0,1)}</div>`:''}).join('');}
function twoWeeksAgo(){const d=new Date();d.setDate(d.getDate()-14);return d.toISOString().slice(0,10);}

// ── NAV ───────────────────────────────────────────────────────────────────
function nav(page,btn){currentNav=page;document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));const t=btn||document.querySelector(`[data-nav="${page}"]`);if(t)t.classList.add('active');filterAE='all';renderPage();}
function renderPage(undoLabel){updateBadges();renderAEPods();const pages={overview:renderOverview,campaigns:renderCampaigns,accounts:renderAccounts,oneons:renderOneons,todos:renderTodos,notes:renderNotes,links:renderLinks,summary:renderSummaryPage,events:renderEvents,recap:renderRecap,wins:renderWins,activity:renderActivity};const el=document.getElementById('ws-main');if(el)el.innerHTML=(pages[currentNav]||renderOverview)();if(window._undoSnap){showUndoBar(undoLabel||'Saved',window._undoSnap,5);window._undoSnap=null;}}
function updateBadges(){const nc=document.getElementById('nb-c');const na=document.getElementById('nb-a');const nt=document.getElementById('nb-t');if(nc)nc.textContent=S.campaigns.length;if(na)na.textContent=S.accounts.length;if(nt)nt.textContent=AES.reduce((n,ae)=>n+(S.todos[ae.id]||[]).filter(t=>!t.done).length,0);}

// ── AE PODS ───────────────────────────────────────────────────────────────
function renderAEPods(){const el=document.getElementById('ae-pods-sb');if(!el)return;el.innerHTML=AES.map(ae=>{const camps=S.campaigns.filter(c=>(c.aes||[]).includes(ae.id)).length;const accts=S.accounts.filter(a=>a.aeId===ae.id).length;const sel=filterAE===ae.id;return `<button class="ae-pod-btn${sel?' active':''}" onclick="filterByAE('${ae.id}')"><div class="ae-av" style="background:${ae.bg};color:${ae.color};border-color:${ae.color+'40'}">${ae.name.split(' ').map(w=>w[0]).join('').slice(0,2)}</div><div style="flex:1;min-width:0"><div class="ae-pod-name">${ae.name.split(' ')[0]} ${ae.name.split(' ')[1]}</div><div class="ae-pod-ct">${accts} acct${accts!==1?'s':''} · ${camps} camp${camps!==1?'s':''}</div></div>${sel?'<div class="ae-active-dot"></div>':''}</button>`;}).join('');}
function filterByAE(id){filterAE=filterAE===id?'all':id;renderPage();}
function aeTabs(active,fn){return `<div class="tabs"><button class="tab${active==='all'?' active':''}" onclick="${fn}('all')">All AEs</button>${AES.map(ae=>`<button class="tab${active===ae.id?' active':''}" onclick="${fn}('${ae.id}')">${ae.name.split(' ')[0]}</button>`).join('')}</div>`;}

// ── OVERVIEW ──────────────────────────────────────────────────────────────
function renderOverview(){
  const fa=filterAE;const camps=fa==='all'?S.campaigns:S.campaigns.filter(c=>(c.aes||[]).includes(fa));const accts=fa==='all'?S.accounts:S.accounts.filter(a=>a.aeId===fa);
  const allTodosRaw=[...AES,{id:'general',name:'General'}].flatMap(ae=>(S.todos[ae.id]||[]).map(t=>({...t,_aeId:t._aeId||ae.id,_aeName:t._aeName||ae.name})));
  const seen=new Set();const todos=allTodosRaw.filter(t=>{if(seen.has(t.id))return false;seen.add(t.id);return true;}).filter(t=>{if(fa==='all')return true;if(t._isCampEmail)return(t._allAeIds||[t._aeId]).includes(fa);return t._aeId===fa;});
  const open=todos.filter(t=>!t.done);const activeCamps=camps.filter(c=>c.status==='Active');
  const campTasks=open.filter(t=>t._isCampEmail&&t.due).sort((a,b)=>a.due.localeCompare(b.due));
  const genTasks=open.filter(t=>!t._isCampEmail).sort((a,b)=>(a.due||'9').localeCompare(b.due||'9'));
  const overdue=open.filter(t=>t.due&&isOverdue(t.due)).length;
  const nn=fa==='all'?AES.flatMap(ae=>(S.notes[ae.id]||[]).map(n=>({...n,_ae:ae}))):(S.notes[fa]||[]).map(n=>({...n,_ae:aeById(fa)}));
  const rn=[...nn].sort((a,b)=>b.date.localeCompare(a.date)).slice(0,3);
  const ae=fa!=='all'?aeById(fa):null;
  let html=`<div class="page-hd"><div><div class="page-title">${ae?ae.name+' — Pod':'Commercial Illinois &amp; Midwest'}</div><div class="page-sub">Q2 FY26 · ${accts.length} accounts · ${open.length} open tasks</div></div><div class="hd-acts"><button class="btn btn-ghost btn-sm" onclick="openQuickAdd()">+ Quick Add</button><button class="btn btn-primary btn-sm" onclick="nav('summary',null)">📋 Generate Summary</button></div></div>${aeTabs(fa,'setOvF')}<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;align-items:start">`;
  // Campaign tasks
  html+=`<div><div class="card"><div class="card-head card-head-accent"><span style="font-size:14px">📧</span><div class="card-title">Campaign Tasks</div><span style="font-size:11px;color:var(--text3)">${campTasks.length} due</span><button class="btn btn-ghost btn-sm" style="margin-left:auto" onclick="todoTab='campaign';nav('todos',null)">All →</button></div><div style="padding:0">`;
  if(!campTasks.length)html+=`<div style="text-align:center;padding:20px;color:var(--text3);font-size:12px">No campaign tasks due.</div>`;
  else campTasks.slice(0,8).forEach(t=>{const od=isOverdue(t.due);html+=`<div class="todo-item" style="padding:9px 14px;border-bottom:1px solid var(--border)"><div class="todo-chk" onclick="toggleTodo('${t._aeId}','${t.id}')"></div><div style="flex:1;min-width:0"><div style="font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${t.label}</div><div style="font-size:10px;color:${od?'var(--red)':'var(--text3)'}">${t._aeName?t._aeName+' · ':''}${od?'Overdue':'Due '+fmtDate(t.due)}</div></div></div>`;});
  html+=`</div></div></div>`;
  // General tasks
  html+=`<div><div class="card"><div class="card-head card-head-accent"><span style="font-size:14px">✅</span><div class="card-title">To Do</div>${overdue?`<span style="font-size:10px;padding:1px 7px;border-radius:10px;background:rgba(217,48,37,0.08);color:var(--red);font-weight:600">${overdue} overdue</span>`:''}<div style="display:flex;gap:5px;margin-left:auto"><button class="btn btn-ghost btn-sm" onclick="openAddTodo()">+ Add</button><button class="btn btn-ghost btn-sm" onclick="nav('todos',null)">All →</button></div></div><div style="padding:0">`;
  if(!genTasks.length)html+=`<div style="text-align:center;padding:20px;color:var(--text3);font-size:12px">Nothing to do.</div>`;
  else genTasks.slice(0,8).forEach(t=>{const od=t.due&&isOverdue(t.due);html+=`<div class="todo-item" style="padding:9px 14px;border-bottom:1px solid var(--border)"><div class="todo-chk${t.done?' done':''}" onclick="toggleTodo('${t._aeId}','${t.id}')">${t.done?'✓':''}</div><div style="flex:1;min-width:0"><div style="font-size:12px;color:${t.done?'var(--text3)':'var(--text)'};text-decoration:${t.done?'line-through':'none'};overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${t.label}</div><div style="font-size:10px;color:${od?'var(--red)':'var(--text3)'}">${t._aeName?t._aeName+' · ':''}${t.due?(od?'Overdue':'Due '+fmtDate(t.due)):'No due date'}</div></div><span class="pill ${priClass(t.priority)}" style="flex-shrink:0">${t.priority}</span></div>`;});
  html+=`</div></div></div>`;
  // Campaigns + notes
  html+=`<div style="display:flex;flex-direction:column;gap:14px"><div class="card"><div class="card-head" style="background:linear-gradient(135deg,#032D42,#064663);padding:12px 14px"><div style="flex:1"><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.6);margin-bottom:2px">Active Campaigns</div><div style="font-size:28px;font-weight:800;color:#fff;line-height:1">${activeCamps.length}</div><div style="font-size:10px;color:rgba(255,255,255,.5);margin-top:2px">${camps.filter(c=>c.status==='Complete').length} completed</div></div><button class="btn btn-sm" style="background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.2);font-size:10px" onclick="nav('campaigns',null)">View All →</button></div><div style="max-height:280px;overflow-y:auto">`;
  if(!activeCamps.length)html+=`<div style="text-align:center;padding:20px;color:var(--text3);font-size:12px">No active campaigns.<br><br><button class="btn btn-primary btn-sm" onclick="openAddCampaign()">+ New Campaign</button></div>`;
  else activeCamps.forEach(c=>{const sentCount=Object.keys(c.sentLog||{}).length;html+=`<div style="padding:10px 14px;border-bottom:1px solid var(--border);cursor:pointer" onclick="openCampSlide('${c.id}','details')"><div style="display:flex;align-items:center;gap:6px;margin-bottom:4px"><div style="font-size:12px;font-weight:700;color:var(--sn-blue);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.name}</div>${aeBubbles(c.aes)}</div><div style="display:flex;align-items:center;gap:8px"><div style="flex:1;height:4px;background:var(--bg3);border-radius:2px;overflow:hidden"><div style="height:100%;width:${Math.round(sentCount/(c.totalSteps||5)*100)}%;background:var(--sn-blue);border-radius:2px"></div></div><span style="font-size:10px;color:var(--text3)">${sentCount}/${c.totalSteps||5}</span></div><div style="font-size:10px;color:var(--text3);margin-top:3px">${c.contactCount||0} contacts · ${c.product||'—'}</div></div>`;});
  html+=`</div></div>`;
  // Pinned notes
  html+=`<div class="card"><div class="card-head card-head-accent"><span style="font-size:14px">📌</span><div class="card-title">Pinned Notes</div><div style="display:flex;gap:5px;margin-left:auto"><button class="btn btn-ghost btn-sm" onclick="openAddNote()">+ Add</button><button class="btn btn-ghost btn-sm" onclick="nav('notes',null)">All →</button></div></div><div class="card-body">`;
  if(!rn.length)html+=`<div style="text-align:center;padding:14px;color:var(--text3);font-size:12px">No notes pinned.</div>`;
  else rn.forEach(n=>{html+=`<div class="note-block"><div style="display:flex;gap:6px;margin-bottom:4px"><span style="font-size:10px;color:var(--amber);font-weight:700">${n.author||'Jacob'}</span><span style="font-size:10px;color:var(--text3)">${fmtDate(n.date)}${n._ae?' · '+n._ae.name.split(' ')[0]:''}</span></div><div style="font-size:12px;color:var(--text2);line-height:1.6">${n.text.length>120?n.text.slice(0,120)+'…':n.text}</div></div>`;});
  html+=`</div></div></div></div>`;return html;
}
function setOvF(id){filterAE=id;renderPage();}

// ── CAMPAIGNS ─────────────────────────────────────────────────────────────
let campAEF='all';
function renderCampaigns(){
  campAEF=filterAE;const camps=campAEF==='all'?S.campaigns:S.campaigns.filter(c=>(c.aes||[]).includes(campAEF));
  let html=`<div class="page-hd"><div><div class="page-title">Campaigns</div><div class="page-sub">Email copy, send dates, and step tracking</div></div><div class="hd-acts"><button class="btn btn-primary btn-sm" onclick="openAddCampaign()">+ New Campaign</button></div></div>${aeTabs(campAEF,'setCampAEF')}`;
  if(!camps.length)return html+`<div class="card"><div class="card-body"><div style="text-align:center;padding:30px;color:var(--text3);font-size:12px">No campaigns yet.</div></div></div>`;
  const active=camps.filter(c=>c.status!=='Complete');const completed=camps.filter(c=>c.status==='Complete');
  function renderCard(c){
    const stepsArr=c.steps&&c.steps.length?c.steps:Array.from({length:c.totalSteps||3},(_,i)=>({type:'email',emailNum:i+1}));
    const sentLog=c.sentLog||{};const total=c.contactCount||0;const isComplete=c.status==='Complete';
    const SMETA={email:{icon:'📧',label:'Email',color:'var(--sn-blue)',bg:'rgba(3,45,66,0.06)'},call:{icon:'📞',label:'Call',color:'#0369A1',bg:'rgba(3,105,161,0.06)'},linkedin:{icon:'🔗',label:'LinkedIn',color:'#5B21B6',bg:'rgba(91,33,182,0.06)'},voicemail:{icon:'📱',label:'Voicemail',color:'#0369A1',bg:'rgba(3,105,161,0.06)'}};
    const progressDots=stepsArr.map((_,i)=>{const isSent=!!(sentLog[i+1]);const m=SMETA[stepsArr[i]?.type]||SMETA.email;return `<div title="Step ${i+1}${isSent?' — sent':''}" style="width:10px;height:10px;border-radius:50%;background:${isSent?'#1a7a00':'transparent'};border:1.5px solid ${isSent?'#1a7a00':m.color};flex-shrink:0"></div>`;}).join('');
    const sentCount=Object.values(sentLog).filter(Boolean).length;const allSent=stepsArr.every((_,i)=>!!(sentLog[i+1]));
    return `<div class="card" style="margin-bottom:10px"><div onclick="campToggleExpand('${c.id}',this)" style="padding:12px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;user-select:none" class="card-head card-head-accent"><div style="flex:1;min-width:0"><div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap"><div class="card-title" style="margin:0">${c.name}</div>${statusPill(c.status)}<div style="display:flex;gap:2px">${(c.aes||[]).map(id=>{const a=aeById(id);return a?`<span style="font-size:10px;font-weight:600;padding:1px 6px;border-radius:10px;border:1px solid ${a.color+'30'};background:${a.bg};color:${a.color}">${a.init}</span>`:''}).join('')}</div></div><div style="display:flex;align-items:center;gap:8px;margin-top:6px"><div style="display:flex;gap:4px">${progressDots}</div><span style="font-size:10px;color:var(--text3)">${sentCount}/${stepsArr.length} steps · ${total} contacts${c.product?' · '+c.product:''}</span></div></div><div style="display:flex;gap:4px;flex-shrink:0" onclick="event.stopPropagation()"><div class="btn-icon" onclick="openCampSlide('${c.id}','emails')">✎</div><div class="btn-icon del" onclick="deleteCampConfirm('${c.id}')">×</div></div><span class="camp-chevron" style="font-size:11px;color:var(--text3)">▶</span></div><div class="camp-body" style="display:none"><div style="padding:12px 14px;display:flex;gap:8px;overflow-x:auto;border-top:1px solid var(--border)">${stepsArr.map((step,i)=>{const sm=SMETA[step.type]||SMETA.email;const isEmail=step.type==='email';const eIdx=step.emailNum||i+1;const em=isEmail?(c.emails||{})[eIdx]:null;const sentEntry=sentLog[i+1];const isSent=!!sentEntry;return `<div style="flex-shrink:0;width:175px;border:1px solid ${isSent?'rgba(26,122,0,0.3)':'var(--border)'};border-radius:var(--r2);padding:9px 11px;background:${isSent?'rgba(26,122,0,0.04)':sm.bg}"><div style="display:flex;align-items:center;gap:5px;margin-bottom:5px"><span style="font-size:11px;font-weight:700;color:${sm.color}">${sm.icon} ${sm.label}${isEmail?' '+eIdx:''}</span>${isSent?`<span class="pill pill-g" style="font-size:9px">sent</span>`:''}</div><div style="font-size:10px;color:var(--text2);margin-bottom:6px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${isEmail?(em?.subject||'No copy yet'):(step.notes?.slice(0,26)||'No notes')}</div><div style="display:flex;align-items:center;gap:5px"><label style="display:flex;align-items:center;gap:4px;cursor:pointer;font-size:11px;color:${isSent?'#1a7a00':'var(--text2)'}"><input type="checkbox" ${isSent?'checked':''} onchange="toggleStepSent('${c.id}',${i+1},this.checked)" style="accent-color:#1a7a00;width:13px;height:13px">${isSent?'Sent':'Mark sent'}</label>${isEmail?`<div class="btn-icon" style="width:20px;height:20px;font-size:10px;margin-left:auto" onclick="viewCampEmail('${c.id}',${eIdx})">👁</div>`:''}</div></div>`;}).join('')}</div><div style="padding:10px 14px;border-top:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-wrap:wrap"><div style="display:flex;align-items:center;gap:6px"><span style="font-size:11px;color:var(--text3)">Contacts:</span><input type="number" min="0" class="form-input" style="width:70px;padding:4px 7px;font-size:12px" value="${total}" onchange="updateCampCount('${c.id}','contactCount',parseInt(this.value)||0)"></div><div style="margin-left:auto;display:flex;gap:6px">${allSent&&!isComplete?`<button class="btn btn-sm" style="background:#1a7a00;color:#fff;border:none" onclick="completeCampaign('${c.id}')">✓ Complete</button>`:''}${c.sourceSheetUrl?`<a href="${c.sourceSheetUrl}" target="_blank" class="btn btn-ghost btn-sm" style="text-decoration:none;color:#0369A1">📊 Sheet ↗</a>`:''}</div></div></div></div>`;
  }
  if(active.length)active.forEach(c=>{html+=renderCard(c);});else html+=`<div class="card"><div class="card-body"><div style="text-align:center;padding:20px;color:var(--text3);font-size:12px">No active campaigns.</div></div></div>`;
  if(completed.length){html+=`<div style="margin-top:10px"><button onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'':'none'" style="width:100%;display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);cursor:pointer;font-size:12px;font-weight:600;color:var(--text2)"><span>▶</span>Completed (${completed.length})</button><div style="display:none">${completed.map(c=>renderCard(c)).join('')}</div></div>`;}
  return html;
}
function campToggleExpand(campId,el){const card=el.closest('.card');if(!card)return;const body=card.querySelector('.camp-body');const chev=card.querySelector('.camp-chevron');if(!body)return;const open=body.style.display==='none'||body.style.display==='';body.style.display=open?'block':'none';if(chev)chev.textContent=open?'▼':'▶';}
function setCampAEF(id){campAEF=id;filterAE=id;renderPage();}
function completeCampaign(id){const c=S.campaigns.find(x=>x.id===id);if(!c)return;withUndo('Campaign completed',()=>{c.status='Complete';c.completedAt=today();markDirty('bdr2_camps');window._undoSnap=snapshotState();scheduleSaveNow();renderPage('Campaign completed');});}
function updateCampCount(campId,field,val){const c=S.campaigns.find(x=>x.id===campId);if(!c)return;c[field]=val;markDirty('bdr2_camps');clearTimeout(saveTimer);setSaveInd('· unsaved');saveTimer=setTimeout(saveAll,3000);}
function deleteCampConfirm(id){const c=S.campaigns.find(x=>x.id===id);if(!c)return;if(!confirm(`Delete "${c.name}"?`))return;withUndo('Campaign deleted',()=>{S.campaigns=S.campaigns.filter(x=>x.id!==id);AES.forEach(ae=>{if(S.todos[ae.id])S.todos[ae.id]=S.todos[ae.id].filter(t=>t._campId!==id);});saveCamps();saveTodos();renderPage('Campaign deleted');});}
function toggleStepSent(campId,step,checked){const c=S.campaigns.find(x=>x.id===campId);if(!c)return;if(!c.sentLog)c.sentLog={};if(checked){c.sentLog[step]={date:today()};}else{delete c.sentLog[step];}saveCamps();renderPage();toast(checked?'Step '+step+' marked sent':'Step '+step+' unmarked',checked?'ok':'');}
function viewCampEmail(campId,step){const c=S.campaigns.find(x=>x.id===campId);if(!c)return;const em=(c.emails||{})[step];if(!em||(!em.subject&&!em.body)){toast('No email written for step '+step+' yet');return;}window._previewCopyText=(em.subject?'Subject: '+em.subject+'\n\n':'')+em.body;showModal('Email '+step+' — '+c.name,`<div style="margin-bottom:12px;padding:10px 12px;background:var(--bg2);border-radius:var(--r2)"><div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:4px">Subject</div><div style="font-size:13px;font-weight:600;color:var(--sn-blue)">${em.subject||'<span style="color:var(--text3);font-weight:400">No subject</span>'}</div></div><div style="padding:13px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);font-size:13px;color:var(--text);line-height:1.8;white-space:pre-wrap;max-height:320px;overflow-y:auto">${em.body||'<span style="color:var(--text3);font-style:italic">No body yet.</span>'}</div><div style="margin-top:10px;display:flex;gap:8px"><button class="btn btn-green btn-sm" onclick="navigator.clipboard.writeText(window._previewCopyText||'').then(()=>toast('Copied','ok'))">Copy</button><button class="btn btn-ghost btn-sm" onclick="closeModal();openCampSlide('${campId}','emails')">Edit →</button></div>`,null,true);}

// ── CAMPAIGN SLIDE ────────────────────────────────────────────────────────
function openAddCampaign(){
  const aeChecks=AES.map(ae=>`<label class="cb-row"><input type="checkbox" name="ae-cb" value="${ae.id}"><span>${ae.name}</span></label>`).join('');
  showModal('New Campaign',`<div class="form-row"><label class="form-label">Campaign Name *</label><input class="form-input" id="m-cn" placeholder="Veza Awareness Q2"></div><div class="form-row"><label class="form-label">Product / Focus</label><input class="form-input" id="m-cp" placeholder="Veza, ITAM, Now Assist…"></div><div class="form-2"><div class="form-row"><label class="form-label">Emails</label><select class="form-select" id="m-emails"><option>3</option><option>4</option><option>5</option></select></div><div class="form-row"><label class="form-label">Include Calls?</label><select class="form-select" id="m-calls"><option value="no">No</option><option value="yes">Yes — between emails</option></select></div></div><div class="form-row"><label class="form-label">Source Sheet URL</label><input class="form-input" id="m-csheet" placeholder="https://…"></div><div class="form-row"><label class="form-label">Assign to AEs</label><div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:4px">${aeChecks}</div></div><div class="form-row"><label class="form-label">Notes</label><textarea class="form-textarea" id="m-cnotes" placeholder="ICP, messaging angle, strategy…"></textarea></div>`,()=>{
    const name=document.getElementById('m-cn').value.trim();if(!name){toast('Name required');return;}
