<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Outreach Center — ServiceNow BDR</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;}
:root{
  --ink:#032D42;--ink-nav:#01161f;--ink-mid:#043d5a;--ink-lt:#044355;
  --wasabi:#63DF4E;--wdk:#4ab83a;
  --white:#fff;--bg:#F4F4F4;
  --s50:#f8fafc;--s100:#f1f5f9;--s200:#e2e8f0;--s300:#cbd5e1;
  --s400:#94a3b8;--s500:#64748b;--s600:#475569;--s700:#334155;
  --s800:#1e293b;--s900:#0f172a;
  --b50:#eff6ff;--b100:#dbeafe;--b500:#3b82f6;--b600:#2563eb;
  --g50:#f0fdf4;--g100:#dcfce7;--g500:#22c55e;--g600:#16a34a;
  --a50:#fffbeb;--a100:#fef3c7;--a500:#f59e0b;--a600:#d97706;
  --r50:#fff1f2;--r100:#ffe4e6;--r500:#ef4444;--r600:#dc2626;
  --p50:#faf5ff;--p500:#a855f7;--p600:#9333ea;
  /* Workspace tokens */
  --sn-blue:#032D42;--sn-green:#63DF4E;--sn-teal:#044355;--sn-mint:#81B5A1;
  --sn-lgray:#F4F4F4;--sn-mgray:#D3D3D3;
  --surface:#fff;--border:#E2E8ED;--border2:#CBD5DC;
  --text:#032D42;--text2:#4A6070;--text3:#8FA3B1;
  --green-dim:rgba(99,223,78,.12);--blue-dim:rgba(3,45,66,.07);
  --red:#D93025;--red-dim:rgba(217,48,37,.1);
  --amber:#B45309;--amber-dim:rgba(180,83,9,.1);
  --purple:#5B21B6;--purple-dim:rgba(91,33,182,.1);
  --r:8px;--r2:5px;
  --shadow:0 1px 3px rgba(3,45,66,.08),0 1px 2px rgba(3,45,66,.06);
  --shadow2:0 4px 12px rgba(3,45,66,.1);
  --font:'DM Sans','Calibri',sans-serif;--mono:'DM Mono',monospace;
}
body{font-family:var(--font);background:var(--bg);color:var(--text);font-size:13px;line-height:1.5;}
a{text-decoration:none;color:inherit;}
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--sn-mgray);border-radius:2px;}

/* ── GLOBAL NAV ── */
.gnav{height:44px;background:var(--ink-nav);display:flex;align-items:center;position:fixed;top:0;left:0;right:0;z-index:400;border-bottom:1px solid rgba(255,255,255,.06);}
.gnav-logo{display:flex;align-items:center;padding:0 14px;height:44px;border-right:1px solid rgba(255,255,255,.07);flex-shrink:0;}
.gnav-tabs{display:flex;align-items:center;}
.gnav-tab{display:flex;align-items:center;height:44px;padding:0 13px;font-size:12px;color:rgba(255,255,255,.5);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;}
.gnav-tab:hover{color:rgba(255,255,255,.8);background:rgba(255,255,255,.04);}
.gnav-pill-wrap{flex:1;display:flex;justify-content:center;}
.gnav-pill{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:500;padding:4px 12px;border-radius:20px;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.8);cursor:pointer;}
.gnav-pill-dot{width:6px;height:6px;border-radius:50%;background:var(--wasabi);}
.gnav-r{display:flex;align-items:center;gap:2px;padding:0 10px;}
.gnav-btn{width:30px;height:30px;display:flex;align-items:center;justify-content:center;border-radius:4px;color:rgba(255,255,255,.45);cursor:pointer;font-size:13px;border:none;background:transparent;}
.gnav-btn:hover{background:rgba(255,255,255,.07);color:rgba(255,255,255,.8);}
.gnav-av{width:28px;height:28px;background:var(--wasabi);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--ink);cursor:pointer;margin-left:4px;}

/* ── DARK SIDEBAR ── */
.sbar{position:fixed;top:44px;left:0;bottom:0;width:44px;background:#0d1f2b;border-right:1px solid rgba(255,255,255,.05);z-index:300;display:flex;flex-direction:column;overflow:hidden;transition:width .22s cubic-bezier(.4,0,.2,1);}
.sbar:hover{width:180px;box-shadow:4px 0 20px rgba(0,0,0,.25);}
.sbar-sec{padding:10px 0 4px;}
.sbar-lbl{font-size:9px;font-weight:700;letter-spacing:.10em;text-transform:uppercase;color:rgba(255,255,255,.20);padding:0 14px;margin-bottom:2px;display:block;white-space:nowrap;opacity:0;transition:opacity .15s .05s;}
.sbar:hover .sbar-lbl{opacity:1;}
.sbar-item{display:flex;align-items:center;gap:10px;padding:8px 14px;font-size:12px;color:rgba(255,255,255,.50);border-left:2px solid transparent;transition:background .12s,color .12s;text-decoration:none;white-space:nowrap;}
.sbar-item:hover{background:rgba(255,255,255,.05);color:rgba(255,255,255,.85);}
.sbar-item.on{color:var(--wasabi);border-left-color:var(--wasabi);background:rgba(99,223,78,.06);font-weight:500;}
.sbar-ic{width:16px;min-width:16px;text-align:center;font-size:15px;flex-shrink:0;}
.sb{margin-left:auto;font-size:9px;font-weight:600;padding:1px 5px;border-radius:8px;background:rgba(255,255,255,.08);color:rgba(255,255,255,.40);opacity:0;transition:opacity .1s;flex-shrink:0;}
.sbar:hover .sb{opacity:1;}
.sb.r{background:rgba(239,68,68,.20);color:#fca5a5;}
.sdiv{height:1px;background:rgba(255,255,255,.06);margin:5px 10px;}
.sbar-footer{padding:8px 14px 10px;font-size:9px;color:rgba(255,255,255,.14);margin-top:auto;white-space:nowrap;opacity:0;transition:opacity .15s;}
.sbar:hover .sbar-footer{opacity:1;}

/* ── MAIN SHELL ── */
.main{margin-top:44px;margin-left:44px;height:calc(100vh - 44px);display:flex;flex-direction:column;overflow:hidden;}

/* ── WORKSPACE TOOLBAR (secondary actions) ── */
.ws-toolbar{height:46px;background:var(--sn-blue);display:flex;align-items:center;padding:0 16px;gap:10px;flex-shrink:0;border-bottom:1px solid rgba(255,255,255,.08);}
.ws-ctx{font-size:11px;color:rgba(255,255,255,.5);letter-spacing:.03em;}
.ws-title{font-size:13px;font-weight:600;color:#fff;letter-spacing:.01em;}
.ws-sep{width:1px;height:18px;background:rgba(255,255,255,.18);}
.ws-right{margin-left:auto;display:flex;align-items:center;gap:7px;}
.save-ind{font-size:10px;color:rgba(255,255,255,.45);font-family:var(--mono);}
.tb-btn{padding:5px 12px;border-radius:var(--r2);font-size:11px;font-weight:600;cursor:pointer;font-family:var(--font);transition:all .15s;}
.tb-btn-primary{background:var(--sn-green);color:var(--sn-blue);border:none;}
.tb-btn-primary:hover{background:#7AE966;}
.tb-btn-ghost{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2);}
.tb-btn-ghost:hover{background:rgba(255,255,255,.18);}

/* ── WORKSPACE BODY ── */
.ws-body{display:flex;flex:1;overflow:hidden;}

/* ── WORKSPACE LIGHT SIDEBAR ── */
.ws-sidebar{width:216px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;}
.sb-logo-area{padding:12px 14px 10px;border-bottom:1px solid var(--border);}
.sb-logo-text{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);}
.sb-sec{padding:10px 8px 6px;}
.sb-lbl{font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);padding:0 6px 7px;}
.nav-btn{display:flex;align-items:center;gap:9px;width:100%;padding:7px 8px;border-radius:var(--r);cursor:pointer;border:1px solid transparent;margin-bottom:1px;background:none;transition:all .12s;text-align:left;font-family:var(--font);}
.nav-btn:hover{background:var(--sn-lgray);}
.nav-btn.active{background:var(--green-dim);border-color:rgba(99,223,78,.35);}
.nav-icon{width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.nav-lbl{font-size:12px;font-weight:500;color:var(--text);flex:1;}
.nav-sub{font-size:10px;color:var(--text3);margin-top:1px;}
.nav-badge{font-size:10px;font-weight:700;padding:1px 7px;border-radius:10px;}
.nb-g{background:var(--green-dim);color:#1a7a00;}
.nb-a{background:var(--amber-dim);color:var(--amber);}
.nb-r{background:var(--red-dim);color:var(--red);}
.nb-b{background:var(--blue-dim);color:var(--sn-blue);}
.ae-pod-btn{display:flex;align-items:center;gap:8px;width:100%;padding:6px 8px;border-radius:var(--r);cursor:pointer;border:1px solid transparent;margin-bottom:1px;background:none;transition:all .12s;}
.ae-pod-btn:hover{background:var(--sn-lgray);}
.ae-pod-btn.active{background:var(--green-dim);border-color:rgba(99,223,78,.35);}
.ae-av{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;flex-shrink:0;border:1.5px solid transparent;}
.ae-pod-name{font-size:11px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.ae-pod-ct{font-size:10px;color:var(--text3);}
.ae-active-dot{width:6px;height:6px;border-radius:50%;background:var(--sn-green);flex-shrink:0;}

/* ── WORKSPACE CONTENT ── */
.ws-content{flex:1;overflow-y:auto;padding:20px 24px;background:var(--sn-lgray);}

/* ── WORKSPACE COMPONENTS ── */
.pill{display:inline-flex;align-items:center;font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;white-space:nowrap;}
.pill-g{background:rgba(26,122,0,.1);color:#1a7a00;}
.pill-a{background:var(--amber-dim);color:var(--amber);}
.pill-r{background:var(--red-dim);color:var(--red);}
.pill-b{background:var(--blue-dim);color:var(--sn-blue);}
.pill-p{background:var(--purple-dim);color:var(--purple);}
.pill-t{background:rgba(4,67,85,.1);color:var(--sn-teal);}
.pill-m{background:#EAEAEA;color:var(--text2);}
.btn{padding:6px 14px;border-radius:var(--r2);font-size:12px;font-weight:600;cursor:pointer;font-family:var(--font);transition:all .15s;}
.btn-primary{background:var(--sn-blue);color:#fff;border:none;}
.btn-primary:hover{background:var(--sn-teal);}
.btn-green{background:var(--sn-green);color:var(--sn-blue);border:none;}
.btn-green:hover{background:#7AE966;}
.btn-ghost{background:var(--surface);color:var(--text2);border:1px solid var(--border2);}
.btn-ghost:hover{background:var(--sn-lgray);}
.btn-sm{padding:4px 10px;font-size:11px;}
.btn-icon{width:26px;height:26px;border-radius:var(--r2);background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:11px;color:var(--text3);transition:all .12s;flex-shrink:0;}
.btn-icon:hover{background:var(--sn-lgray);border-color:var(--border2);color:var(--text);}
.btn-icon.del:hover{border-color:rgba(217,48,37,.3);color:var(--red);}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:14px;box-shadow:var(--shadow);}
.card-head{padding:13px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-wrap:wrap;background:var(--surface);}
.card-head-accent{border-top:3px solid var(--sn-blue);}
.card-title{font-size:13px;font-weight:600;color:var(--text);flex:1;}
.card-body{padding:14px 16px;}
.tabs{display:flex;gap:2px;margin-bottom:16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r2);padding:3px;overflow-x:auto;box-shadow:var(--shadow);}
.tab{padding:6px 12px;border-radius:4px;font-size:12px;font-weight:500;cursor:pointer;color:var(--text3);white-space:nowrap;transition:all .12s;border:1px solid transparent;background:none;font-family:var(--font);}
.tab:hover{color:var(--text2);background:var(--sn-lgray);}
.tab.active{background:var(--sn-blue);color:#fff;border-color:var(--sn-blue);}
.page-hd{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;}
.page-title{font-size:20px;font-weight:700;color:var(--sn-blue);letter-spacing:-.02em;}
.page-sub{font-size:11px;color:var(--text3);margin-top:3px;}
.hd-acts{display:flex;gap:8px;}
.kpi-row{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:20px;}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px;position:relative;overflow:hidden;box-shadow:var(--shadow);}
.kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.kpi-b::after{background:var(--sn-blue);}
.kpi-g::after{background:var(--sn-green);}
.kpi-a::after{background:#D97706;}
.kpi-r::after{background:var(--red);}
.kpi-p::after{background:var(--purple);}
.kpi-lbl{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);}
.kpi-val{font-size:24px;font-weight:700;margin:4px 0 2px;letter-spacing:-.02em;color:var(--sn-blue);}
.kpi-sub{font-size:10px;color:var(--text3);}
.form-row{margin-bottom:12px;}
.form-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:4px;display:block;}
.form-input{width:100%;padding:8px 10px;background:#F4F4F4;border:1px solid var(--border2);border-radius:var(--r2);color:var(--text);font-size:13px;font-family:var(--font);}
.form-input:focus{outline:none;border-color:var(--sn-blue);background:var(--surface);}
.form-select{width:100%;padding:8px 10px;background:#F4F4F4;border:1px solid var(--border2);border-radius:var(--r2);color:var(--text);font-size:13px;font-family:var(--font);}
.form-select:focus{outline:none;border-color:var(--sn-blue);}
.form-textarea{width:100%;padding:8px 10px;background:#F4F4F4;border:1px solid var(--border2);border-radius:var(--r2);color:var(--text);font-size:12px;font-family:var(--font);resize:vertical;min-height:70px;}
.form-textarea:focus{outline:none;border-color:var(--sn-blue);background:var(--surface);}
.form-2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.cb-row{display:flex;align-items:center;gap:7px;padding:5px 0;cursor:pointer;}
.cb-row input{accent-color:var(--sn-blue);width:14px;height:14px;}
.cb-row span{font-size:12px;color:var(--text2);}
.modal-bg{position:fixed;inset:0;background:rgba(3,45,66,.5);display:flex;align-items:center;justify-content:center;z-index:999;backdrop-filter:blur(3px);}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);width:500px;max-width:96vw;max-height:90vh;overflow-y:auto;box-shadow:var(--shadow2);}
.modal.wide{width:680px;}
.modal-hd{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--surface);z-index:2;}
.modal-title{font-size:15px;font-weight:700;color:var(--sn-blue);}
.modal-close{width:26px;height:26px;border-radius:50%;background:#F4F4F4;border:none;color:var(--text2);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;}
.modal-body{padding:18px 20px;}
.modal-foot{padding:12px 20px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;position:sticky;bottom:0;background:var(--surface);}
.toast{position:fixed;bottom:20px;right:20px;padding:9px 15px;background:var(--sn-blue);color:#fff;border-radius:var(--r);font-size:12px;font-weight:600;z-index:1000;transform:translateY(50px);opacity:0;transition:all .22s;pointer-events:none;box-shadow:var(--shadow2);}
.toast.show{transform:translateY(0);opacity:1;}
.toast.ok{background:var(--sn-teal);}
.slide{position:fixed;top:44px;right:0;bottom:0;width:min(920px,calc(100vw - 260px));background:var(--surface);border-left:1px solid var(--border);z-index:500;overflow-y:auto;transform:translateX(100%);transition:transform .25s cubic-bezier(.4,0,.2,1);box-shadow:-4px 0 20px rgba(3,45,66,.1);}
.slide.open{transform:translateX(0);}
.slide-hd{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;position:sticky;top:0;background:var(--surface);z-index:5;}
.slide-body{padding:18px;}
.sdot{width:9px;height:9px;border-radius:50%;background:var(--sn-mgray);cursor:pointer;transition:all .15s;flex-shrink:0;border:1.5px solid var(--border2);}
.sdot.done{background:var(--sn-green);border-color:#45b834;box-shadow:0 0 0 2px rgba(99,223,78,.2);}
.sdot.curr{background:#D97706;border-color:#B45309;}
.tbl{width:100%;border-collapse:collapse;}
.tbl th{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);text-align:left;padding:0 10px 9px 0;border-bottom:2px solid var(--border);}
.tbl td{padding:9px 10px 9px 0;border-bottom:1px solid var(--border);vertical-align:middle;}
.tbl tr:last-child td{border-bottom:none;}
.tbl tr:hover td{background:#F4F4F4;}
.crow{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);}
.crow:last-child{border-bottom:none;}
.cav{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;}
.todo-item{display:flex;align-items:flex-start;gap:9px;padding:8px 0;border-bottom:1px solid var(--border);}
.todo-item:last-child{border-bottom:none;}
.todo-chk{width:15px;height:15px;border:1.5px solid var(--border2);border-radius:3px;flex-shrink:0;margin-top:1px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:9px;transition:all .15s;}
.todo-chk.done{background:var(--green-dim);border-color:#45b834;color:#1a7a00;}
.note-block{border-left:3px solid #D97706;background:rgba(180,83,9,.04);border-radius:0 var(--r2) var(--r2) 0;padding:10px 13px;margin-bottom:9px;}
.note-block:last-child{margin-bottom:0;}
.sec-hd{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--text3);padding-bottom:8px;border-bottom:1px solid var(--border);margin-bottom:12px;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.g32{display:grid;grid-template-columns:2fr 1fr;gap:14px;}
.summary-output{background:var(--sn-blue);color:#fff;border-radius:var(--r);padding:20px;font-size:13px;line-height:1.8;font-family:var(--font);}
.summary-section-head{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:#63DF4E !important;margin-top:16px;margin-bottom:6px;border-top:1px solid rgba(99,223,78,.2);padding-top:12px;}
.summary-loading{display:flex;align-items:center;gap:10px;color:rgba(255,255,255,.6);font-size:12px;}
.spinner{width:16px;height:16px;border:2px solid rgba(99,223,78,.3);border-top-color:var(--sn-green);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.ae-chips{display:flex;flex-wrap:wrap;gap:4px;}
.ae-chip{display:inline-flex;align-items:center;gap:3px;font-size:10px;font-weight:600;padding:2px 7px;border-radius:10px;border:1px solid var(--border2);}
.link-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.link-card{padding:11px 13px;background:#F4F4F4;border:1px solid var(--border);border-radius:var(--r2);cursor:pointer;transition:all .15s;}
.link-card:hover{border-color:var(--sn-blue);background:var(--surface);}
.date-pill{display:inline-block;font-size:10px;background:#F4F4F4;border:1px solid var(--border);border-radius:4px;padding:2px 5px;font-family:var(--mono);color:var(--text2);}
.sn-footer{text-align:center;padding:16px 0 4px;font-size:9px;color:var(--text3);}
</style>
</head>
<body>

<!-- ── GLOBAL NAV ── -->
<nav class="gnav">
  <div class="gnav-logo">
