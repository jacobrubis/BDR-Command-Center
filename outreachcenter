padding:8px 12px;background:rgba(180,83,9,0.06);border-left:3px solid var(--amber);border-radius:0 var(--r2) var(--r2) 0;margin-top:8px"><div style="font-size:10px;font-weight:700;color:var(--amber);text-transform:uppercase;margin-bottom:3px">📌 Pinned</div><div style="font-size:12px;color:var(--text2)">${o.pinnedNote}</div></div>`:''}</div></div>`;});return html;}
