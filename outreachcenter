    const steps=[];for(let e=1;e<=emailCount;e++){steps.push({type:'email',emailNum:e});if(e<emailCount&&addCalls)steps.push({type:'call',notes:''});}
    const aes=[...document.querySelectorAll('input[name="ae-cb"]:checked')].map(i=>i.value);
    withUndo('Campaign added',()=>{S.campaigns.push({id:uid(),name,product:document.getElementById('m-cp').value,totalSteps:steps.length,steps,status:'Active',accountMotion:'both',aes,acctIds:[],notes:document.getElementById('m-cnotes').value,sourceSheetUrl:document.getElementById('m-csheet').value,contactCount:0,stepCounts:{},emails:{},createdAt:today()});saveCamps();closeModal();renderPage('Campaign added');toast(name+' created','ok');});
  });
}
function openCampSlide(id,tab){
  const c=S.campaigns.find(x=>x.id===id);if(!c)return;if(!c.emails)c.emails={};
  const showTab=tab||'emails';const stepsArr=c.steps&&c.steps.length?c.steps:Array.from({length:c.totalSteps||3},(_,i)=>({type:'email',emailNum:i+1}));
  if(!c.steps||!c.steps.length)c.steps=stepsArr;
  document.getElementById('slide-title').textContent=c.name;document.getElementById('slide-sub').textContent=(c.product||'Campaign')+' · '+stepsArr.length+'-step sequence';
  const SMETA={email:{icon:'📧',label:'Email'},call:{icon:'📞',label:'Call'},voicemail:{icon:'📱',label:'Voicemail'},linkedin:{icon:'🔗',label:'LinkedIn'}};
  function buildStep(step,idx){
    const meta=SMETA[step.type]||SMETA.email;const isEmail=step.type==='email';const eIdx=step.emailNum||idx+1;const em=isEmail?(c.emails[eIdx]||{}):{};const hasCopy=isEmail?!!(em.subject||em.body):!!(step.notes);
    return `<div style="border:1px solid var(--border);border-radius:var(--r2);overflow:hidden;margin-bottom:8px"><div onclick="seqToggle(${idx})" style="padding:9px 13px;background:rgba(3,45,66,0.04);display:flex;align-items:center;gap:8px;cursor:pointer"><div style="width:22px;height:22px;border-radius:50%;background:rgba(3,45,66,0.12);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:var(--sn-blue)">${idx+1}</div><span style="font-size:12px;font-weight:700;color:var(--sn-blue)">${meta.icon} ${meta.label}${isEmail?' '+eIdx:''}</span>${hasCopy?`<span style="font-size:10px;color:#1a7a00">✓ written</span>`:`<span style="font-size:10px;color:var(--text3)">no copy</span>`}${isEmail?`<span style="font-size:10px;color:var(--text3);margin-left:auto" id="sl-chars-${eIdx}">${(em.body||'').length} chars</span>`:''}<span id="seq-toggle-${idx}" style="font-size:10px;color:var(--text3);margin-left:${isEmail?'4px':'auto'}">▶</span><button onclick="event.stopPropagation();seqRemoveStep('${id}',${idx})" style="background:none;border:none;cursor:pointer;color:var(--text3);font-size:14px">×</button></div><div id="seq-body-${idx}" style="padding:11px 13px;display:none">${isEmail?`<div style="display:grid;grid-template-columns:1fr 180px;gap:10px;margin-bottom:8px"><div><label class="form-label">Subject</label><input class="form-input" id="sl-subj-${eIdx}" value="${(em.subject||'').replace(/"/g,'&quot;')}" placeholder="Subject…" style="font-size:12px"></div><div><label class="form-label">Send Date</label><input type="date" class="form-input" id="sl-date-${eIdx}" value="${em.sendDate||''}" style="font-size:12px"></div></div><label class="form-label">Email Body</label><textarea class="form-textarea" id="sl-body-${eIdx}" style="min-height:160px;font-size:12px;line-height:1.6" oninput="document.getElementById('sl-chars-${eIdx}').textContent=this.value.length+' chars'">${em.body||''}</textarea>${hasCopy?`<div style="margin-top:8px"><button class="btn btn-green btn-sm" onclick="navigator.clipboard.writeText(document.getElementById('sl-body-${eIdx}').value).then(()=>toast('Copied','ok'))">📋 Copy</button></div>`:''}`:
    `<div class="form-row"><label class="form-label">Send Date</label><input type="date" class="form-input" id="sl-sdate-${idx}" value="${step.sendDate||''}" style="max-width:180px"></div><label class="form-label">Notes</label><textarea class="form-textarea" id="sl-notes-${idx}" style="min-height:80px">${step.notes||''}</textarea>`}</div></div>`;
  }
  let emailsTab=`<div style="margin-bottom:10px;padding:9px 11px;background:var(--blue-dim);border-radius:var(--r2);font-size:11px;color:var(--sn-blue)">Use <code>[Name]</code> and <code>[Company]</code> tokens. Set send dates to auto-create tasks.</div><div id="seq-list">${stepsArr.map((s,i)=>buildStep(s,i)).join('')}</div><div style="border:1px dashed var(--border);border-radius:var(--r2);padding:10px 14px;margin-bottom:12px"><div style="font-size:10px;font-weight:700;text-transform:uppercase;color:var(--text3);margin-bottom:8px">+ Add Step</div><div style="display:flex;gap:6px;flex-wrap:wrap"><button class="btn btn-ghost btn-sm" onclick="seqAddStep('${id}','email')">📧 Email</button><button class="btn btn-ghost btn-sm" onclick="seqAddStep('${id}','call')">📞 Call</button><button class="btn btn-ghost btn-sm" onclick="seqAddStep('${id}','linkedin')">🔗 LinkedIn</button><button class="btn btn-ghost btn-sm" onclick="seqAddStep('${id}','voicemail')">📱 Voicemail</button></div></div><button class="btn btn-primary btn-sm" onclick="saveCampEmails('${id}')">Save Sequence</button>`;
  const checks=AES.map(ae=>`<label class="cb-row"><input type="checkbox" id="sl-ae-${ae.id}" ${(c.aes||[]).includes(ae.id)?'checked':''}><span>${ae.name}</span></label>`).join('');
  let detailsTab=`<div class="form-row"><label class="form-label">Name</label><input class="form-input" id="sl-cn" value="${c.name}"></div><div class="form-2"><div class="form-row"><label class="form-label">Product</label><input class="form-input" id="sl-cp" value="${c.product||''}"></div><div class="form-row"><label class="form-label">Status</label><select class="form-select" id="sl-cs">${CAMP_STATUSES.map(s=>`<option${s===c.status?' selected':''}>${s}</option>`)}</select></div></div><div class="form-row"><label class="form-label">Source Sheet</label><div style="display:flex;gap:6px"><input class="form-input" id="sl-sheet" value="${c.sourceSheetUrl||''}" style="flex:1">${c.sourceSheetUrl?`<a href="${c.sourceSheetUrl}" target="_blank" class="btn btn-ghost btn-sm" style="text-decoration:none">↗</a>`:''}</div></div><div class="form-row"><label class="form-label">AEs</label><div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:4px">${checks}</div></div><div class="form-row"><label class="form-label">Notes</label><textarea class="form-textarea" id="sl-cn2">${c.notes||''}</textarea></div><div style="display:flex;align-items:center;justify-content:space-between;margin-top:4px"><button class="btn btn-primary btn-sm" onclick="saveCampDetails('${id}')">Save</button><button class="btn btn-sm" style="background:rgba(217,48,37,0.08);color:var(--red);border:1px solid rgba(217,48,37,0.2);font-size:11px" onclick="closeSlide();deleteCampConfirm('${id}')">🗑 Delete</button></div>`;
  document.getElementById('slide-body').innerHTML=`<div style="display:flex;gap:2px;margin-bottom:16px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:3px"><button class="tab${showTab==='emails'?' active':''}" id="sl-tab-emails" onclick="slideSwitchTab('emails')" style="flex:1">Email Sequence</button><button class="tab${showTab==='details'?' active':''}" id="sl-tab-details" onclick="slideSwitchTab('details')" style="flex:1">Campaign Details</button></div><div id="sl-emails" style="display:${showTab==='emails'?'':'none'}">${emailsTab}</div><div id="sl-details" style="display:${showTab==='details'?'':'none'}">${detailsTab}</div>`;
  document.getElementById('slide').classList.add('open');
}
function slideSwitchTab(tab){document.getElementById('sl-emails').style.display=tab==='emails'?'':'none';document.getElementById('sl-details').style.display=tab==='details'?'':'none';document.getElementById('sl-tab-emails').className='tab'+(tab==='emails'?' active':'');document.getElementById('sl-tab-details').className='tab'+(tab==='details'?' active':'');}
function seqToggle(idx){const b=document.getElementById('seq-body-'+idx);const t=document.getElementById('seq-toggle-'+idx);if(!b)return;const open=b.style.display==='none'||!b.style.display;b.style.display=open?'block':'none';if(t)t.textContent=open?'▼':'▶';}
function seqAddStep(campId,type){const c=S.campaigns.find(x=>x.id===campId);if(!c)return;if(!c.steps||!c.steps.length)c.steps=Array.from({length:c.totalSteps||3},(_,i)=>({type:'email',emailNum:i+1}));if(type==='email'){const used=c.steps.filter(s=>s.type==='email').map(s=>s.emailNum||0);let n=1;while(used.includes(n))n++;c.steps.push({type:'email',emailNum:n});}else c.steps.push({type,notes:''});c.totalSteps=c.steps.length;saveCamps();openCampSlide(campId,'emails');}
function seqRemoveStep(campId,idx){const c=S.campaigns.find(x=>x.id===campId);if(!c||!c.steps)return;if(c.steps.length<=1){toast('Must have at least 1 step');return;}c.steps.splice(idx,1);c.totalSteps=c.steps.length;saveCamps();openCampSlide(campId,'emails');}
function saveCampEmails(id){const c=S.campaigns.find(x=>x.id===id);if(!c)return;if(!c.emails)c.emails={};const stepsArr=c.steps&&c.steps.length?c.steps:Array.from({length:c.totalSteps||3},(_,i)=>({type:'email',emailNum:i+1}));stepsArr.forEach((step,idx)=>{if(step.type==='email'){const eIdx=step.emailNum||idx+1;c.emails[eIdx]={subject:document.getElementById('sl-subj-'+eIdx)?.value||'',body:document.getElementById('sl-body-'+eIdx)?.value||'',sendDate:document.getElementById('sl-date-'+eIdx)?.value||''};}else{step.notes=document.getElementById('sl-notes-'+idx)?.value||'';step.sendDate=document.getElementById('sl-sdate-'+idx)?.value||'';}});c.steps=stepsArr;c.totalSteps=stepsArr.length;syncCampEmailTodos(c);saveCamps();toast('Sequence saved','ok');}
function saveCampDetails(id){const c=S.campaigns.find(x=>x.id===id);if(!c)return;c.name=document.getElementById('sl-cn').value;c.product=document.getElementById('sl-cp').value;c.status=document.getElementById('sl-cs').value;c.sourceSheetUrl=document.getElementById('sl-sheet').value;c.notes=document.getElementById('sl-cn2').value;c.aes=AES.filter(ae=>document.getElementById('sl-ae-'+ae.id)?.checked).map(ae=>ae.id);saveCamps();renderPage();toast('Saved','ok');document.getElementById('slide-title').textContent=c.name;}
function syncCampEmailTodos(c){const stepsArr=c.steps&&c.steps.length?c.steps:[];const assignedAEs=c.aes&&c.aes.length?c.aes:[AES[0].id];const primaryAE=assignedAEs[0];const aeNames=assignedAEs.map(id=>aeById(id)?.name.split(' ')[0]).filter(Boolean);const TLABELS={email:'📧 Send Email',call:'📞 Call',linkedin:'🔗 LinkedIn',voicemail:'📱 Voicemail'};const doneByStep={};[...AES.map(ae=>ae.id),'general'].forEach(aeId=>{(S.todos[aeId]||[]).forEach(t=>{if(t._campId===c.id&&t._isCampEmail&&t.done)doneByStep[t._step]=true;});});[...AES.map(ae=>ae.id),'general'].forEach(aeId=>{if(!S.todos[aeId])return;S.todos[aeId]=S.todos[aeId].filter(t=>!(t._campId===c.id&&t._isCampEmail));});if(!S.todos[primaryAE])S.todos[primaryAE]=[];stepsArr.forEach((step,idx)=>{const stepNum=idx+1;const isEmail=step.type==='email';const eIdx=isEmail?(step.emailNum||stepNum):null;const sendDate=isEmail?((c.emails||{})[eIdx]?.sendDate||''):(step.sendDate||'');if(!sendDate)return;const label=`${TLABELS[step.type]||'📋 Step'} ${isEmail?eIdx:'(Step '+stepNum+')'} — ${c.name}`;S.todos[primaryAE].push({id:uid(),label,due:sendDate,priority:'Med',account:c.name,accounts:aeNames,done:doneByStep[stepNum]||false,_campId:c.id,_step:stepNum,_isCampEmail:true,_aeId:primaryAE,_aeName:aeNames.join(', '),_allAeIds:assignedAEs});});}

// ── WINS ──────────────────────────────────────────────────────────────────
function renderWins(){
  const wins=[...(S.wins||[])].sort((a,b)=>b.date.localeCompare(a.date));const wAEF=filterAE;const filtered=wAEF==='all'?wins:wins.filter(w=>w.aeId===wAEF);const total=filtered.reduce((s,w)=>s+(parseFloat(w.pipeline)||0),0);
  let html=`<div class="page-hd"><div><div class="page-title">Wins</div><div class="page-sub">${filtered.length} meeting${filtered.length!==1?'s':''} booked${total?' · $'+total.toLocaleString():''}</div></div><div class="hd-acts"><button class="btn btn-primary btn-sm" onclick="openAddWin()">+ Log Win</button></div></div>${aeTabs(wAEF,'setWinsAEF')}`;
  if(!filtered.length)return html+`<div class="card"><div class="card-body"><div style="text-align:center;padding:40px;color:var(--text3);font-size:12px">No wins logged yet.<br><br><button class="btn btn-primary btn-sm" onclick="openAddWin()">Log your first win →</button></div></div></div>`;
  const byMonth={};filtered.forEach(w=>{const m=w.date.slice(0,7);if(!byMonth[m])byMonth[m]=[];byMonth[m].push(w);});
  Object.entries(byMonth).sort((a,b)=>b[0].localeCompare(a[0])).forEach(([month,mwins])=>{
    const label=new Date(month+'-15').toLocaleDateString('en-US',{month:'long',year:'numeric'});html+=`<div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);padding:8px 0 6px">${label} · ${mwins.length} win${mwins.length!==1?'s':''}</div>`;
    mwins.forEach(w=>{const ae=aeById(w.aeId);const acct=S.accounts.find(a=>a.id===w.acctId);const camp=S.campaigns.find(c=>c.id===w.campId);html+=`<div class="card" style="margin-bottom:8px"><div class="card-head" style="padding:12px 16px;border-top:3px solid #1a7a00"><div style="flex:1;min-width:0"><div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:3px"><span style="font-size:13px;font-weight:700;color:var(--sn-blue)">${w.contactName}</span>${w.contactTitle?`<span style="font-size:11px;color:var(--text2)">${w.contactTitle}</span>`:''} ${acct?`<span style="font-size:11px;font-weight:600;color:var(--text2)">${acct.name}</span>`:''} ${ae?`<span style="font-size:10px;font-weight:600;padding:1px 7px;border-radius:10px;background:${ae.bg};color:${ae.color}">${ae.init}</span>`:''}<span style="font-size:10px;color:var(--text3)">${fmtDate(w.date)}</span>${w.pipeline?`<span style="font-size:11px;font-weight:700;color:#1a7a00">$${Number(w.pipeline).toLocaleString()}</span>`:''}</div>${camp?`<div style="font-size:10px;color:var(--text3)">via ${camp.name}</div>`:''} ${w.notes?`<div style="font-size:11px;color:var(--text2);margin-top:5px;line-height:1.5">${w.notes}</div>`:''}</div><div style="display:flex;gap:4px"><div class="btn-icon" onclick="editWin('${w.id}')">✎</div><div class="btn-icon del" onclick="deleteWin('${w.id}')">×</div></div></div></div>`;});
  });return html;
}
function setWinsAEF(id){filterAE=id;renderPage();}
function openAddWin(){
