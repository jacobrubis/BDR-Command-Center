// ── TODOS ─────────────────────────────────────────────────────────────────
let todoAEF='all',todoTab='general';
function renderTodos(){
  todoAEF=filterAE;const allBuckets=[...AES.map(ae=>({id:ae.id,name:ae.name.split(' ')[0]})),{id:'general',name:'General'}];const all=allBuckets.flatMap(ae=>(S.todos[ae.id]||[]).map(t=>({...t,_aeId:t._aeId||ae.id,_aeName:t._aeName||ae.name})));const seen=new Set();const deduped=all.filter(t=>{if(seen.has(t.id))return false;seen.add(t.id);return true;});
  const filtered=todoAEF==='all'?deduped:todoAEF==='general'?deduped.filter(t=>t._aeId==='general'&&!t._isCampEmail):deduped.filter(t=>t._isCampEmail?(t._allAeIds||[t._aeId]).includes(todoAEF):t._aeId===todoAEF);
  const campTasks=filtered.filter(t=>t._isCampEmail);const generalTasks=filtered.filter(t=>!t._isCampEmail);const shown=todoTab==='campaign'?campTasks:generalTasks;const open=shown.filter(t=>!t.done).sort((a,b)=>(a.due||'9').localeCompare(b.due||'9'));const done=shown.filter(t=>t.done);const overdue=open.filter(t=>t.due&&isOverdue(t.due));
  let html=`<div class="page-hd"><div><div class="page-title">To Do</div><div class="page-sub">${open.length} open · ${overdue.length} overdue</div></div><div class="hd-acts">${todoTab==='general'?'<button class="btn btn-primary btn-sm" onclick="openAddTodo()">+ Add Task</button>':''}</div></div><div class="tabs"><button class="tab${todoAEF==='all'?' active':''}" onclick="setTodoAEF('all')">All AEs</button>${AES.map(ae=>`<button class="tab${todoAEF===ae.id?' active':''}" onclick="setTodoAEF('${ae.id}')">${ae.name.split(' ')[0]}</button>`).join('')}<button class="tab${todoAEF==='general'?' active':''}" onclick="setTodoAEF('general')" style="border-left:1px solid var(--border);margin-left:4px;padding-left:12px">General</button></div><div style="display:flex;gap:2px;margin-bottom:14px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:3px;max-width:320px"><button class="tab${todoTab==='general'?' active':''}" onclick="todoTab='general';renderPage()" style="flex:1">To Do (${generalTasks.filter(t=>!t.done).length})</button><button class="tab${todoTab==='campaign'?' active':''}" onclick="todoTab='campaign';renderPage()" style="flex:1">Campaign Tasks (${campTasks.filter(t=>!t.done).length})</button></div>`;
  if(overdue.length)html+=`<div class="card" style="border-color:rgba(217,48,37,.25)"><div class="card-head" style="border-top:3px solid var(--red)"><span>⚠️</span><div class="card-title" style="color:var(--red)">Overdue (${overdue.length})</div></div><div class="card-body">${overdue.map(t=>todoRow(t)).join('')}</div></div>`;
  html+=`<div class="card"><div class="card-head card-head-accent"><span>▶</span><div class="card-title">Upcoming (${open.filter(t=>!isOverdue(t.due)).length})</div></div><div class="card-body">${open.filter(t=>!isOverdue(t.due)).map(t=>todoRow(t)).join('')||'<div style="text-align:center;padding:20px;color:var(--text3);font-size:12px">Nothing upcoming.</div>'}</div></div>`;
  if(done.length)html+=`<div class="card"><div class="card-head card-head-accent"><span>✓</span><div class="card-title">Done (${done.length})</div><div class="btn-icon del" onclick="clearDone()">🗑</div></div><div class="card-body">${done.slice(-8).reverse().map(t=>todoRow(t)).join('')}</div></div>`;
  return html;
}
function todoRow(t){const od=!t.done&&t.due&&isOverdue(t.due);const badge=t._isCampEmail?`<span class="pill pill-b" style="font-size:9px;padding:1px 6px">📧 Step ${t._step}</span>`:'';return `<div class="todo-item"><div class="todo-chk${t.done?' done':''}" onclick="toggleTodo('${t._aeId}','${t.id}')">${t.done?'✓':''}</div><div style="flex:1;min-width:0"><div style="font-size:12px;color:${t.done?'var(--text3)':'var(--text)'};text-decoration:${t.done?'line-through':'none'};display:flex;align-items:center;gap:6px;flex-wrap:wrap">${t.label} ${badge}</div><div style="display:flex;align-items:center;gap:6px;margin-top:3px;flex-wrap:wrap">${t._aeName?`<span style="font-size:10px;color:var(--text3)">${t._aeName}</span>`:''} ${t.due?`<span style="color:${od?'var(--red)':'var(--text3)'};font-size:10px">${od?'Overdue':'Due '+fmtDate(t.due)}</span>`:`<span style="font-size:10px;color:var(--text3)">No due date</span>`}</div></div><span class="pill ${priClass(t.priority)}">${t.priority}</span><div class="btn-icon del" onclick="delTodo('${t._aeId}','${t.id}')">×</div></div>`;}
